@using System.Text.Json
@using System.Text.Json.Serialization
@using System.Collections.Concurrent
@using ERP_Web.Components.Custom
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject ILogger<VoiceRecognition> Logger

<div class="voice-recognition-container">
    <!-- 图标填充按钮 -->
    <button id="toggleBtn-@Id" 
            class="voice-icon-btn @(IsRecognizing ? "recording" : "")" 
            @onclick="ToggleVoice"
            title="@(IsRecognizing ? "停止录音" : "开始录音")">
        @if (IsRecognizing)
        {
            <Icon Type="audio-muted" Theme="IconThemeType.Outline" class="icon-fill" />
        }
        else
        {
            <Icon Type="audio" Theme="IconThemeType.Outline" class="icon-fill" />
        }
    </button>
</div>

<style>
    /* 图标按钮容器 */
    .voice-icon-btn {
        width: 35px;
        height: 35px;
        padding: 0;
        margin: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background-color: #f0f0f0;
        border: 1px solid #d9d9d9;
        cursor: pointer;
        transition: all 0.3s;
        position: relative;
        overflow: hidden;
    }
    
    /* 图标填充整个按钮 */
    .icon-fill {
        width: 100%;
        height: 100%;
        padding: 8px; /* 控制图标大小 */
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    /* 确保SVG图标填充容器 */
    .icon-fill svg {
        width: 100%;
        height: 100%;
        fill: currentColor;
    }
    
    /* 悬停状态 */
    .voice-icon-btn:hover {
        background-color: #e6f7ff;
        border-color: #1890ff;
    }
    
    /* 录音状态 */
    .voice-icon-btn.recording {
        background-color: #fff1f0;
        border-color: #ffa39e;
        animation: pulse 1.5s infinite;
    }
    
    .voice-icon-btn.recording .icon-fill {
        color: #f5222d;
    }
    
    .voice-icon-btn:not(.recording) .icon-fill {
        color: #1890ff;
    }
    
    /* 脉冲动画 */
    @@keyframes pulse {
        0% { 
            transform: scale(0.95); 
            box-shadow: 0 0 0 0 rgba(245, 34, 45, 0.7);
        }
        70% { 
            transform: scale(1); 
            box-shadow: 0 0 0 8px rgba(245, 34, 45, 0);
        }
        100% { 
            transform: scale(0.95); 
            box-shadow: 0 0 0 0 rgba(245, 34, 45, 0);
        }
    }
    
    /* 容器样式 */
    .voice-recognition-container {
        display: inline-block;
        margin: 5px;
    }
</style>


