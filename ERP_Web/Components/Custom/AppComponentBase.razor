using ERP_Web.Core.Service;
using ERP_Web.Models.PrivilegeHub;
using Microsoft.AspNetCore.Components;

namespace ERP_Web.Components
{
    public class AppComponentBase : ComponentBase
    {
        [Inject] protected IUserContext UserContext { get; set; }

        /// <summary>
        /// 页面组件直接用CurrentUser获取当前登录用户，无需重复注入/查询
        ///
        </summary>
        protected User? CurrentUser => UserContext.CurrentUser;

        protected override async Task OnInitializedAsync()
        {
            // 自动初始化用户信息，页面不需要再写获取逻辑
            await UserContext.GetCurrentUserAsync();
            await base.OnInitializedAsync();
        }
    }
}
