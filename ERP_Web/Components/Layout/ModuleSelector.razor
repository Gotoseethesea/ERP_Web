@page "/module-selector"
@layout EmptyLayout

@using Microsoft.AspNetCore.Authorization
@using ERP_Web.Models.PrivilegeHub
@using Components.Layout
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject NavigationManager NavManager
@inject IJSRuntime JsRuntime

<Row Align="RowAlign.Middle" Justify="RowJustify.Center" Style="min-height:100vh;background:linear-gradient(135deg, #667eea 0%, #764ba2 100%);padding:32px 0">
    <Col Style="width:100%;max-width:1200px">
    <div Style="text-align:center;margin-bottom:48px">
        <Title Level="2" Style="color:#fff;margin-bottom:8px">ERP管理系统</Title>
        <Text Style="color:rgba(255,255,255,0.8)">请选择业务模块</Text>
    </div>
    <GridRow gutter="24">
        <!-- 进销存模块 -->
        @foreach (var module in SysModels)
        {
            <GridCol Lg="8" Md="12" Xs="24" Style="margin-bottom:24px">
                <div @onclick="() => SelectModule(module)" style="cursor: pointer;height:100%">
                    <Card Hoverable
                          Style="width:100%;height:100%;border-radius:12px;cursor:pointer"
                          BodyStyle="padding:48px 24px;text-align:center">
                        <Icon Type="@module.Icon" Style="@module.Style" />
                        <Title Level="3" Style="margin-bottom:12px">@module.Name</Title>
                        <Text Type="TextElementType.Secondary">@module.Description</Text>
                    </Card>
                </div>
            </GridCol>
        }
    </GridRow>
    <div Style="text-align:center;margin-top:24px">
        <Text Style="color:rgba(255,255,255,0.6)">© 2026 ERP管理系统 | 版本 V1.0</Text>
    </div>
</Col>
</Row>

@code {
    List<SystemBusinessModule> SysModels;

    protected override async Task OnInitializedAsync()
    {
        //await Refresh();
        SysModels = SystemBusinessModule.Select();
    }

    private async Task SelectModule(SystemBusinessModule module)
    {
        await JsRuntime.InvokeVoidAsync("localStorage.setItem", "currentModule", module.Code);
        await JsRuntime.InvokeVoidAsync("localStorage.setItem", "currentModuleIcon", module.Icon);

        NavManager.NavigateTo("/");
    }
}
