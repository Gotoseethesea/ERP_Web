    // 从浏览器 Cookie 获取用户信息
    private async Task<User?> GetUserFromCookie()
    {
        try
        {
            // 1.1 从 Cookie 中获取用户 ID
            var UserAccount = await GetCookieAsync("UserAccount");
        
            if (string.IsNullOrEmpty(UserAccount))
                return null;
        
            // if (!int.TryParse(userIdStr, out int userId))
            //     return null;
        
            // 1.2 从数据库获取用户信息
            var db = new SqlClient();
            var user = await db.Db.Queryable<User>()
                .Where(u => u.Account == UserAccount)
                .FirstAsync();
        
            return user;
        }
        catch (Exception ex)
        {
            //Logger.LogError(ex, "从 Cookie 获取用户信息失败");
            return null;
        }
    }

    // 动态构建菜单树
    private void BuildMenuTree(HashSet<string> userPermissions)
    {
        var db = new SqlClient();
    
        // 3.1 基础查询
        var query = db.Db.Queryable<AppMenu>()
            .Where(m => m.Active)
            .OrderBy(m => m.Sequence);
    
        // 3.2 根据权限过滤菜单
        if (userPermissions.Count > 0)
        {
            // 如果用户有权限，排除登录菜单
            query = query.Where(m => m.Code != "Login1st");
        
            // 添加权限过滤
            if (!userPermissions.Contains("Admin"))
            {
                // 普通用户只能看到自己权限内的菜单
                query = query.Where(m =>
                    m.PermissionKey == null ||
                    userPermissions.Any(p => m.PermissionKey.Contains(p))
                );
            }
        }
        else
        {
            // 未登录用户只显示登录菜单
            query = query.Where(m => m.Code == "Login1st");
        }
    
        // 3.3 转换为树形结构
        var _menuTree = query.ToTree(
            it => it.Children,
            it => it.ParentId,
            0,
            it => it.Id
        ).ToList();
    }
