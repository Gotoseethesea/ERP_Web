@code{
    /// <summary>
    /// 按模块过滤菜单
    /// </summary>
    private List<AppMenu> FilterMenuByModule(List<AppMenu> menus, string module)
    {
        var filtered = new List<AppMenu>();
        foreach (var menu in menus)
        {
            // 匹配当前模块的菜单
            if (menu.Module == module || menu.Module == "Common" || menu.Module == "Common" == null) // 需给AppMenu实体加Module字段，对应数据库新增Module字段
            {
                // 递归过滤子菜单
                if (menu.Children != null && menu.Children.Any())
                {
                    menu.Children = FilterMenuByModule(menu.Children, module);
                }
                filtered.Add(menu);
            }
        }
        return filtered;
    }

    /// <summary>
    /// 不想改数据库的话用这个，按路由前缀过滤
    /// </summary>
    private List<AppMenu> FilterMenuByPathPrefix(List<AppMenu> menus, string prefix)
    {
        var filtered = new List<AppMenu>();
        foreach (var menu in menus)
        {
            if (menu.Path.StartsWith(prefix) || (menu.Children != null && menu.Children.Any(c => c.Path.StartsWith(prefix))))
            {
                if (menu.Children != null && menu.Children.Any())
                {
                    menu.Children = FilterMenuByPathPrefix(menu.Children, prefix);
                }
                filtered.Add(menu);
            }
        }
        return filtered;
    }

    /// <summary>
    /// 切换模块，跳回选择页
    /// </summary>
    private async Task SwitchModule()
    {
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "currentModule");
        NavigationManager.NavigateTo("/module-selector");
    }
}
@code{

    private readonly IJSRuntime _jsRuntime;

    public async Task<string?> GetCookieAsync(string name)
    {
        try
        {
            return await _jsRuntime.InvokeAsync<string>("getCookie", name);
        }
        catch
        {
            return null;
        }
    }

    public async Task SetCookieAsync(string name, string value, int days = 30)
    {
        await _jsRuntime.InvokeVoidAsync("setCookie", name, value, days);
    }

    public async Task DeleteCookieAsync(string name)
    {
        await _jsRuntime.InvokeVoidAsync("deleteCookie", name);
    }

}
<script>
    window.getCookie = function (name) {
        const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        return match ? decodeURIComponent(match[2]) : null;
    };

    window.setCookie = function (name, value, days) {
        const date = new Date();
        date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
        document.cookie = `${name}=${encodeURIComponent(value)};expires=${date.toUTCString()};path=/;secure;samesite=lax`;
    };

</script>