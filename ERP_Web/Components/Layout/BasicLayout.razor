<AntDesign.ProLayout.BasicLayout 
    Logo="@("https://gw.alipayobjects.com/zos/rmsportal/KDpgvguMpGfqaHPjicRK.svg")"
    MenuData="_menuData"
    NavTheme="AntDesign.MenuTheme.Dark"
    Theme="AntDesign.MenuTheme.Dark"
    Title = "ERP_Web"
    MenuAccordion
    @bind-Collapsed="collapsed">
    <HeaderContentRender>
        <Space Size="@("24")">
            <SpaceItem>
                <Icon Class="action" Type="@(collapsed ? "menu-unfold" : "menu-fold")" OnClick="Toggle" />
            </SpaceItem>
            <SpaceItem>
                <Icon Class="action" Type="reload" Theme="IconThemeType.Outline" OnClick="Reload" />
            </SpaceItem>
            <!-- ✅ 新增：当前模块显示+切换按钮 -->
            <SpaceItem>
                <Button Type="ButtonType.Link" Size="ButtonSize.Large" OnClick="SwitchModule">
                    <Icon Type="@_currentModuleIcon" Style="margin-right:4px" />
                    @_moduleNameMap.GetValueOrDefault(_currentModule, "选择模块")
                </Button>
            </SpaceItem>
            <SpaceItem>
                <Button Type="ButtonType.Link" Size="ButtonSize.Large">星陨阁</Button>
            </SpaceItem>
        </Space>
    </HeaderContentRender>
    <RightContentRender >
        <RightContent/>
    </RightContentRender>
    <ChildContent>
        <ReuseTabs ></ReuseTabs>
       @if (_isLoaded)
        {
            @Body
        }
        else
        {
            <Spin Tip="首次加载中..." Size="SpinSize.Small"></Spin> <!-- Ant Design 加载动画 -->
        }
    </ChildContent>
    <FooterRender>
        <FooterView Copyright="2026 ERP管理系统 | 版本 V1.0" Links="Links"></FooterView>
    </FooterRender>
</AntDesign.ProLayout.BasicLayout>

