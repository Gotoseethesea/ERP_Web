@page "/sales/products"
@using ERP_Web.Models
@using ERP_Web.Repository
@using AntDesign
@inject MessageService MessageService
@inject ModalService ModalService
@inject NavigationManager NavigationManager


<PageHeader Title="商品选择" SubTitle="浏览并选择商品加入购物车"> </PageHeader>
<Space>
    <Button Type="ButtonType.Primary" Icon="shopping-cart" OnClick="ViewCart">查看购物车 (@cartItems.Count)</Button>
    <Button Type="ButtonType.Dashed" Icon="sync" OnClick="RefreshProducts">刷新商品</Button>
</Space>

<Row Gutter="16">
    <!-- 商品列表 -->
    <Col Span="6">
        <Card Title="商品分类" Style="height: 80vh; overflow-y: auto;">
            <Tree DataSource="@categories" TItem="Category" OnClick="OnCategorySelected" ShowLine BlockNode>
                <TitleTemplate Context="node">
                    <Icon Type="@(node.IsLeaf ? "appstore" : "folder")" />
                    <span>@node.DataItem.Name</span>
                </TitleTemplate>
            </Tree>
        </Card>
    </Col>

    <!-- 商品展示 -->
    <Col Span="18">
        <Card Title="商品列表" Style="height: 80vh; overflow-y: auto;">
            <Row Gutter="16">
                @foreach (var product in filteredProducts)
                {
                    <Card Title="@product.Name" Hoverable Style="margin-bottom: 16px; cursor: pointer;">
                        <Cover>
                            <img src="@(product.Image ?? "images/default-product.png")" alt="@product.Name" style="height: 160px; width:160px; object-fit: cover;" />
                        </Cover>
                        <Body>
                            <CardMeta Title="@product.Name" Description="@product.Name">
                            </CardMeta>
                            <div style="padding: 12px;">
                                <Tag Color="TagColor.Red">¥ @product.Specifications.FirstOrDefault()?.Options.FirstOrDefault()?.Price</Tag>
                                <div style="margin-top: 8px;">
                                    <ButtonGroup>
                                        <Space>
                                            <Button Type="ButtonType.Primary" Size="ButtonSize.Small" Block
                                                    OnClick="@(() => NavigateToDetail(product))">
                                                详情
                                            </Button>
                                            <Button Type="ButtonType.Primary" Size="ButtonSize.Small" Block
                                                    OnClick="@(e => ShowSpecSelector(product, e))">
                                                购物车
                                            </Button>
                                        </Space>
                                    </ButtonGroup>
                                </div>
                            </div>
                        </Body>

                    </Card>
                }
            </Row>
        </Card>
    </Col>
</Row>


