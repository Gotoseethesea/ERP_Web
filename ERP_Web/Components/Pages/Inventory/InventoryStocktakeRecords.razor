@page "/inventory-stocktake"
@rendermode InteractiveServer
@using System.ComponentModel
@using AntDesign.TableModels
@using AntDesign.Core.Extensions
@using System.Transactions
@using ERP_Web.Components.Custom
@using ERP_Web.Repository
@using ERP_Web.Models
@using Newtonsoft.Json
@using SqlSugar
@inject ModalService ModalService
@inject IMessageService _message
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<PageHeader Title="库存盘点" SubTitle="库存盘点与盈亏调整"> </PageHeader>
<Card>
    <FilterPanel @ref="filterPanel"
                 Filters="@Filters"
                 FilterModel="@Data"
                 gutter="@gutter"
                 OnSearch="Refresh">
    </FilterPanel>
    <Button Type="ButtonType.Primary" OnClick="() => _createModalVisible = true">
        <Icon Type="plus" /> 新建盘点单
    </Button>
</Card>
@code {
    Dictionary<string, int> gutter = new()
    {
        ["xs"] = 8,
        ["sm"] = 16,
        ["md"] = 24,
        ["lg"] = 32,
        ["xl"] = 48,
        ["xxl"] = 64
    };

    private List<FilterPanel.FilterItem> Filters = new();
    private FilterPanel filterPanel; // 引用组件实例
    IEnumerable<string> MonthSelected, YearSelected, DeptSelected, WarehSelected;  //选择的月份和年度、仓库
    DateOnly?[] DateOnlys = new DateOnly?[2];
    List<string> MonthSe, YearSe;
    List<Warehouse> Warehouses = Warehouse.Select();
    List<Department> Depts = Department.Select();

    /// <summary>
    /// 初始化筛选条件范围
    /// </summary>
    public void FiltrateOnInitialized()
    {
        const int min = 1;
        const int max = 12;
        MonthSe = new List<string>();   //月份选项
        YearSe = new List<string>();    //年度选项

        for (var i = min; max >= i; i++)
        {
            var value = Convert.ToString(i);
            var value2 = Convert.ToString(2022 + i);
            MonthSe.Add(value);
            YearSe.Add(value2);
        }
        if (YearSelected == null || YearSelected.Count() == 0)
        {
            YearSelected = new List<string>() { DateTime.Now.Year.ToString() };
        }

        if (MonthSelected == null || MonthSelected.Count() == 0)
        {
            MonthSelected = new List<string>() { DateTime.Now.Month.ToString() };
        }
        Warehouses = Warehouse.Select();
        Depts = Department.Select();
    }

    /// <summary>
    /// 设置筛选条件选项--生成筛选条件卡片
    /// </summary>
    private void InitializeFilters()
    {
        // 年份筛选
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "年份",
            Type = FilterPanel.FilterType.Select,
            Options = YearSe.Select(y => new FilterPanel.OptionItem { Value = y, Label = y }).ToList(),
            SelectedValues = YearSelected
        });

        // 月份筛选
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "月份",
            Type = FilterPanel.FilterType.Select,
            Options = MonthSe.Select(m => new FilterPanel.OptionItem { Value = m, Label = m }).ToList(),
            SelectedValues = MonthSelected
        });

        // 日期范围
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "日期",
            Type = FilterPanel.FilterType.DateRange,
            DateRange = DateOnlys,
            Span = 12
        });

        // 单号筛选
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "代码",
            Type = FilterPanel.FilterType.Like,
            Placeholder = string.Empty
        });
        // 仓库筛选
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "仓库",
            Type = FilterPanel.FilterType.Select,
            Options = Warehouses.Select(d => new FilterPanel.OptionItem
            {
                Value = d.Code,
                Label = d.Name
            }).ToList()
        });
    }
    // 把你原来注释的这段代码替换成下面的实现
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 只在页面第一次渲染完成后执行一次
        if (firstRender)
        {
            // 延迟0.5秒执行，确保FilterPanel组件完全初始化完成
            await Task.Delay(100);
            // 确保filterPanel已初始化才执行刷新
            if (filterPanel != null)
            {
                // 调用刷新方法，用InvokeAsync保证UI线程安全
                await InvokeAsync(Refresh);
                StateHasChanged();
            }
        }
        await base.OnAfterRenderAsync(firstRender);
    }
}

@code {
    private void NavigateTo(string Code)
    {
        NavManager.NavigateTo($"/inventory-stocktake/edit/{Code}");
    }
}
<!-- 盘点单列表 -->
<Card Bordered="false" Style="margin-top: 16px;">
    <Table TItem="Stocktake" DataSource="@StocktakeList" @ref="Data" PageSize="20" ScrollX="1500" StickyOffsetHeader="64">
        <PropertyColumn Title="盘点单号" Property="val => val.Code" Sortable Width="120px"/>
        <PropertyColumn Title="盘点日期" Property="@(val => val.Date.ToString("yyyy-MM-dd"))" Sortable Width="120px"/>
        <PropertyColumn Title="仓库" Property="@(val => val.Warehouse.Name)" Width="120px" />
        <PropertyColumn Title="状态" Property="@(val => val.StatusText)" Width="120px" />
        <PropertyColumn Title="账面数量" Property="@(val => val.BookQuantity)" Sortable Width="120px" />
        <PropertyColumn Title="实盘数量" Property="@(val => val.ActualQuantity)" Width="120px" />
        <PropertyColumn Title="盘盈数量" Property="@(val => val.ProfitQuantity)" Width="120px" />
        <PropertyColumn Title="盘亏数量" Property="@(val => val.LossQuantity)" Width="120px" />
        <ActionColumn Title="操作" Width="350px">
            <Space>
                <Button Type="ButtonType.Link"
                        OnClick="() => NavigateTo(context.Code)" Disabled="@(context.Status == StocktakeStatus.Adjusted)">
                    <Icon Type="edit" /> 录入实盘
                </Button>

                <Button Type="ButtonType.Link" OnClick="() => GenerateAdjustment(context)" Disabled="@(context.Status != StocktakeStatus.Counted)">
                    <Icon Type="swap" /> 生成调整单
                </Button>
                <Button Type="ButtonType.Link" OnClick="() => PrintStocktake(context)">
                    <Icon Type="printer" /> 打印
                </Button>
                <Popconfirm Title="确定删除该盘点单？" OnConfirm="() => DeleteStocktake(context)" OkText="删除" CancelText="取消">
                    <Button Type="ButtonType.Link" Danger Disabled="@(context.Status == StocktakeStatus.Adjusted)">
                        <Icon Type="delete" /> 删除
                    </Button>
                </Popconfirm>
            </Space>
        </ActionColumn>
    </Table>
</Card>

<!-- 新建盘点单弹窗 -->
<Modal Title="新建盘点单" @bind-Visible="@_createModalVisible" OnOk="CreateStocktake" Width="500">
    <Form Model="@_createForm" LabelColSpan="6" WrapperColSpan="18">
        <FormItem Label="盘点日期">
            <DatePicker @bind-Value="_createForm.SelectedDate" Style="width: 100%;" />
        </FormItem>
        <FormItem Label="盘点仓库">
            <Select TItem="Warehouse"
                    TItemValue="string"
                    DataSource="@Warehouselist"
                    @bind-Value="_createForm.WarehouseCode"
                    ValueName="@nameof(Warehouse.Code)"
                    LabelName="@nameof(Warehouse.Name)"
                    Style="width: 100%;" />
        </FormItem>
    </Form>
</Modal>

@code {
    #region 初始化变量
    private Table<Stocktake> Data;
    private List<Stocktake> StocktakeList = new();
    private List<Warehouse> Warehouselist = new();
    private List<int> YearOptions = Enumerable.Range(DateTime.Now.Year - 3, 7).ToList();

    // 查询条件
    private int SelectedYear = DateTime.Now.Year;
    private int SelectedMonth = DateTime.Now.Month;
    private string SelectedWarehouseCode;

    // 新建弹窗
    private bool _createModalVisible;
    private CreateStocktakeForm _createForm = new();

    // 明细编辑弹窗
    private bool _detailModalVisible;
    private Stocktake _currentStocktake;
    private List<StocktakeDetail> _currentDetailList = new();

    // 打印
    private Stocktake _printStocktake;


    #endregion

    #region 初始化加载
    protected override void OnInitialized()
    {
        FiltrateOnInitialized();
        InitializeFilters();
        Warehouselist = Warehouse.Select();
        // SqlClient SSC = new SqlClient();
        // Warehouselist = SSC.Db.Queryable<Warehouse>().Where(x => x.Active == true).ToList();
        //Refresh();
    }

    // 查询刷新
    public void Refresh()
    {
        var conModels = filterPanel.GenerateConditionalModels();

        SqlClient SSC = new SqlClient();
        var query = SSC.Db.Queryable<Stocktake>()
            .IncludesAllFirstLayer().Where(conModels);

        if (!string.IsNullOrEmpty(SelectedWarehouseCode))
        {
            query = query.Where(x => x.WarehouseCode == SelectedWarehouseCode);
        }
        StocktakeList = query.OrderByDescending(x => x.Date).ToList();
    }
    #endregion

    #region 新建盘点单
    public class CreateStocktakeForm
    {
        public DateOnly SelectedDate = DateOnly.FromDateTime(DateTime.Now);
        public string WarehouseCode;
    }

    public void CreateStocktake()
    {
        if (string.IsNullOrEmpty(_createForm.WarehouseCode))
        {
            _message.Warning("请选择仓库");
            return;
        }

        SqlClient SSC = new SqlClient();
        int fiscalYear = _createForm.SelectedDate.Year;
        int period = _createForm.SelectedDate.Month;

        // 校验该仓库该期间是否已有盘点单
        var exist = SSC.Db.Queryable<Stocktake>()
            .Any(x => x.WarehouseCode == _createForm.WarehouseCode && x.FiscalYear == fiscalYear && x.Period == period && x.Active == true);
        if (exist)
        {
            _message.Error("该仓库当前期间已存在盘点单，请勿重复创建");
            return;
        }

        // 获取当前库存余额
        var invBalances = SSC.Db.Queryable<InventoryBalance>()
            .Includes(x => x.Inv)
            .Where(s => s.WarehouseCode == _createForm.WarehouseCode && s.Quantity > 0).ToList();

        if (!invBalances.Any())
        {
            _message.Warning("该仓库当前无有效库存，无需创建盘点单");
            return;
        }

        // 生成明细
        List<StocktakeDetail> details = new();
        decimal totalQty = 0, totalAmt = 0;
        foreach (var bal in invBalances)
        {
            var detail = new StocktakeDetail
            {
                Id = SnowFlakeSingle.Instance.NextId(),
                InvCode = bal.InvCode,
                SKU = bal.SKU,
                Quantity = bal.Quantity,
                StockCount = 0,
                Price = bal.Price,
                Amount = bal.Amount,
                Active = true,
                FiscalYear = fiscalYear,
                Period = period
            };
            totalQty += bal.Quantity;
            totalAmt += bal.Amount;
            details.Add(detail);
        }

        // 生成盘点单号 规则：WH+年份月份+3位序号
        int maxSeq = SSC.Db.Queryable<Stocktake>()
            .Where(x => x.WarehouseCode == _createForm.WarehouseCode && x.FiscalYear == fiscalYear && x.Period == period)
            .Count() + 1;
        string stocktakeCode = $"{_createForm.WarehouseCode}-{fiscalYear}{period:D2}-{maxSeq:D3}";

        // 保存盘点单
        var stocktake = new Stocktake
        {
            Code = stocktakeCode,
            Date = _createForm.SelectedDate.ToDateTime(TimeOnly.MinValue),
            FiscalYear = fiscalYear,
            Period = period,
            WarehouseCode = _createForm.WarehouseCode,
            Quantity = totalQty,
            Amount = totalAmt,
            Active = true,
            StocktakeDetails = details,
            // 扩展字段：新增Status字段到Stocktake实体类
            Status = StocktakeStatus.Draft
        };

        SSC.Db.InsertNav(stocktake).Include(z => z.StocktakeDetails).ExecuteCommand();
        _createModalVisible = false;
        _message.Success("盘点单创建成功");
        Refresh();
    }
    #endregion

    #region 编辑实盘明细
    private void EditDetail(Stocktake stocktake)
    {
        _currentStocktake = stocktake;
        _currentDetailList = stocktake.StocktakeDetails.ToList();
        _detailModalVisible = true;
    }

    private void SaveDetail()
    {
        SqlClient SSC = new SqlClient();
        // 批量更新明细
        SSC.Db.Updateable(_currentDetailList).ExecuteCommand();
        // 更新盘点单状态为已盘点
        _currentStocktake.Status = StocktakeStatus.Counted;
        SSC.Db.Updateable(_currentStocktake).UpdateColumns(x => x.Status).ExecuteCommand();

        _detailModalVisible = false;
        _message.Success("实盘数据保存成功");
        Refresh();
    }
    #endregion

    #region 生成盘盈盘亏调整单
    private async void GenerateAdjustment(Stocktake stocktake)
    {
        // var confirm = await ModalService.ConfirmAsync("确认生成盘盈盘亏调整单？生成后将自动更新库存，不可撤回", "提示", ConfirmButtons.YesNo, ConfirmIcon.Warning);
        // if (confirm != ConfirmResult.Yes) return;

        try
        {
            using var scope = new TransactionScope();
            SqlClient SSC = new SqlClient();

            // 盘盈明细（入库）
            var profitDetails = stocktake.StocktakeDetails
                .Where(d => d.StockCount > d.Quantity)
                .Select(d => new ITInvInOut
                {
                    InvCode = d.InvCode,
                    SKU = d.Inv?.Specifications?.FirstOrDefault()?.SKU ?? "",
                    Quantity = d.StockCount - d.Quantity,
                    Price = d.Price,
                    Amount = (d.StockCount - d.Quantity) * d.Price
                }).ToList();

            // 盘亏明细（出库）
            var lossDetails = stocktake.StocktakeDetails
                .Where(d => d.StockCount < d.Quantity)
                .Select(d => new ITInvInOut
                {
                    InvCode = d.InvCode,
                    SKU = d.Inv?.Specifications?.FirstOrDefault()?.SKU ?? "",
                    Quantity = d.Quantity - d.StockCount,
                    Price = d.Price,
                    Amount = (d.Quantity - d.StockCount) * d.Price
                }).ToList();

            // 生成盘盈入库单
            if (profitDetails.Any())
            {
                var profitTrx = new InventoryTransaction
                {
                    TrxGroupCode = "PROFIT", // 替换为你系统的盘盈入库类型编码
                    TrxType = 1,
                    WarehouseCode = stocktake.WarehouseCode,
                    Date = DateOnly.FromDateTime(stocktake.Date),
                    FiscalYear = stocktake.FiscalYear.Value,
                    Period = stocktake.Period.Value,
                    SourceDocumentCode = stocktake.Code,
                    ITInvInOuts = profitDetails,
                    Active = true
                };
                profitTrx.Insert(); // 复用你已有的插入方法，自动更新库存
            }

            // 生成盘亏出库单
            if (lossDetails.Any())
            {
                var lossTrx = new InventoryTransaction
                {
                    TrxGroupCode = "LOSS", // 替换为你系统的盘亏出库类型编码
                    TrxType = -1,
                    WarehouseCode = stocktake.WarehouseCode,
                    Date = DateOnly.FromDateTime(stocktake.Date),
                    FiscalYear = stocktake.FiscalYear.Value,
                    Period = stocktake.Period.Value,
                    SourceDocumentCode = stocktake.Code,
                    ITInvInOuts = lossDetails,
                    Active = true
                };
                lossTrx.Insert(); // 复用你已有的插入方法，自动更新库存
            }

            // 更新盘点单状态为已调整
            stocktake.Status = StocktakeStatus.Adjusted;
            SSC.Db.Updateable(stocktake).UpdateColumns(x => x.Status).ExecuteCommand();

            scope.Complete();
            _message.Success("调整单生成成功，库存已更新");
            Refresh();
        }
        catch (Exception ex)
        {
            _message.Error($"生成失败：{ex.Message}");
        }
    }
    #endregion

    #region 打印功能
    private async void PrintStocktake(Stocktake stocktake)
    {

    }
    #endregion

    #region 删除盘点单
    private void DeleteStocktake(Stocktake stocktake)
    {
        SqlClient SSC = new SqlClient();
        // 软删除
        stocktake.Active = false;
        SSC.Db.Updateable(stocktake).UpdateColumns(x => x.Active).ExecuteCommand();
        // 删除明细
        SSC.Db.Updateable<StocktakeDetail>()
            .SetColumns(x => x.Active, false)
            .Where(x => x.StocktakeCode == stocktake.Code)
            .ExecuteCommand();

        _message.Success("删除成功");
        Refresh();
    }
    #endregion

    #region 辅助方法
    private string GetStatusColor(StocktakeStatus status)
    {
        return status switch
        {
            StocktakeStatus.Draft => "orange",
            StocktakeStatus.Counted => "blue",
            StocktakeStatus.Adjusted => "green",
            _ => "default"
        };
    }
    #endregion
}
