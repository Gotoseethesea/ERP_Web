@code {
    private List<IBrowserFile> loadedFiles = [];
    private long maxFileSize = 1024 * 15;  //15MB
    private int maxAllowedFiles = 3;
    private bool isLoading;

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        isLoading = true;
        loadedFiles.Clear();

        foreach (var file in e.GetMultipleFiles(maxAllowedFiles))
        {
            try
            {
                loadedFiles.Add(file);

                // var path = "D:/MyObject/BlazorWebA_excle/upload";
                // if (!Directory.Exists(path))
                // {
                //     Directory.CreateDirectory(path);
                // }

                // var fileName = file.Name;

                // await using FileStream fs = new(path, FileMode.Create);
                // await e.File.OpenReadStream(maxFileSize).CopyToAsync(fs);

                using var memoryStream = new MemoryStream();
                await file.OpenReadStream(maxFileSize).CopyToAsync(memoryStream);
                var smallFileByteArray = memoryStream.ToArray();

                DataTable dtTable = new DataTable();
                List<string> rowList = new List<string>();
                ISheet sheet;
                memoryStream.Position = 0;
                XSSFWorkbook xssWorkbook = new XSSFWorkbook(memoryStream);
                sheet = xssWorkbook.GetSheetAt(0);
                IRow headerRow = sheet.GetRow(0);
                int cellCount = headerRow.LastCellNum;

                for (int j = 0; j < cellCount; j++)
                {
                    ICell cell = headerRow.GetCell(j);
                    DataColumn column;
                    if (cell == null || string.IsNullOrWhiteSpace(cell.ToString())) continue;
                    {
                        column = new DataColumn();
                        column.DataType = System.Type.GetType("System.String");
                        column.ColumnName = cell.ToString();
                        column.ReadOnly = false;
                        column.Unique = false;
                        // Add the Column to the DataColumnCollection.
                        dtTable.Columns.Add(column);
                        // Console.WriteLine($"Success:{JsonSerializer.Serialize(dtTable)}");
                    }
                }
                for (int i = (sheet.FirstRowNum + 1); i <= sheet.LastRowNum; i++)
                {
                    IRow row = sheet.GetRow(i);
                    if (row == null) continue;
                    if (row.Cells.All(d => d.CellType == CellType.Blank)) continue;

                    DataRow Drow;
                    Drow = dtTable.NewRow();

                    for (int j = row.FirstCellNum; j < cellCount; j++)
                    {
                        if (row.GetCell(j) != null)
                        {
                            if (!string.IsNullOrEmpty(row.GetCell(j).ToString()) && !string.IsNullOrWhiteSpace(row.GetCell(j).ToString()))
                            {
                                Drow[j] = row.GetCell(j).ToString();
                            }
                        }
                    }
                    dtTable.Rows.Add(Drow);
                }

                ImportIcInvs = ConvertToModel(dtTable);
                DbIcInvs = ImportIcInvs;

                Console.WriteLine($"Success:{JsonSerializer.Serialize(ImportIcInvs)}");

                // isLoading = false;
            }
            catch (Exception ex)
            {
                Console.WriteLine("File: {FileName} Error: {Error}",
                    file.Name, ex.Message);
            }
        }
        isLoading = false;
        //refresh();

    }

    public static List<M.IcInv> ConvertToModel(DataTable dt)
    {
        List<M.IcInv> ts = new List<M.IcInv>();
        List<M.Category> CategoryList = new List<M.Category>();
        CategoryList = SqlSugarHelper.Db.Queryable<M.Category>().ToList();

        foreach (DataRow dr in dt.Rows)
        {
            M.IcInv t = new M.IcInv();
            DateTime dateTime = DateTime.Now;

            PropertyInfo[] propertys = t.GetType().GetProperties();// 获得此模型的公共属性
            foreach (PropertyInfo pi in propertys)
            {
                if (dt.Columns.Contains(pi.Name))
                {
                    if (!pi.CanWrite) continue;
                    var value = dr[pi.Name];
                    if (value != DBNull.Value)
                    {
                        switch (pi.PropertyType.FullName)
                        {
                            case "System.Decimal":
                                pi.SetValue(t, decimal.Parse(value.ToString()), null);
                                break;
                            case "System.String":
                                pi.SetValue(t, value.ToString(), null);
                                break;
                            case "System.Int32":
                                pi.SetValue(t, int.Parse(value.ToString()), null);
                                break;
                            case "System.DateTime":
                                pi.SetValue(t, DateTime.Parse(value.ToString()), null);
                                break;
                            case "System.Boolean":
                                pi.SetValue(t, value.ToString() == "1" ? true : false, null);
                                break;
                            default:
                                pi.SetValue(t, value, null);
                                break;
                        }
                    }
                }
            }

            t.Category = CategoryList.FirstOrDefault(x => x.Code == t.CategoryCode);

            if (t.Category == null)
            {
                t.CategoryCode = "1";
                t.Category = new M.Category() { Id = 1, Name = "未知分类" };
            }
            ts.Add(t);
        }
        return ts;
    }

    public static class ToModel<T> where T : new()
    {
        /// <summary>
        /// 将DataTable数据源转换成实体类
        /// </summary>
        public static List<T> ConvertToModel(DataTable dt)
        {
            List<T> ts = new List<T>();
            foreach (DataRow dr in dt.Rows)
            {
                T t = new T();
                PropertyInfo[] propertys = t.GetType().GetProperties();// 获得此模型的公共属性
                foreach (PropertyInfo pi in propertys)
                {
                    if (dt.Columns.Contains(pi.Name))
                    {
                        if (!pi.CanWrite) continue;
                        var value = dr[pi.Name];
                        if (value != DBNull.Value)
                        {
                            switch (pi.PropertyType.FullName)
                            {
                                case "System.Decimal":
                                    pi.SetValue(t, decimal.Parse(value.ToString()), null);
                                    break;
                                case "System.String":
                                    pi.SetValue(t, value.ToString(), null);
                                    break;
                                case "System.Int32":
                                    pi.SetValue(t, int.Parse(value.ToString()), null);
                                    break;
                                default:
                                    pi.SetValue(t, value, null);
                                    break;
                            }
                        }
                    }
                }
                ts.Add(t);
            }
            return ts;
        }
    }
}

