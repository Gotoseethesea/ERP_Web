@code {
    public List<M.IcInv> icInvs = new();
    public string path;
    public string file;
    public string fileName;
    void OnInitializedImport()
    {
        path = "D:/ComputerScience/Git/down";
        if (!Directory.Exists(path))
        {
            Directory.CreateDirectory(path);
        }
    }

    public async Task DownloadFileAsync()
    {
        DataTable dataTable = ToDataTable(DbIcInvs);
        XSSFWorkbook workbook = new XSSFWorkbook();
        var sheet = workbook.CreateSheet("Sheet1");
        var headerRow = sheet.CreateRow(0);
        for (int i = 0; i < dataTable.Columns.Count; i++)
        {
            headerRow.CreateCell(i).SetCellValue(dataTable.Columns[i].ColumnName);
        }
        for (int i = 0; i < dataTable.Rows.Count; i++)
        {
            var dataRow = sheet.CreateRow(i + 1);
            for (int j = 0; j < dataTable.Columns.Count; j++)
            {
                dataRow.CreateCell(j).SetCellValue(dataTable.Rows[i][j]?.ToString() ?? string.Empty);
            }
        }

        if (!Directory.Exists(path))
        {
            Directory.CreateDirectory(path);
        }

        var fileName = "存货档案.xlsx";
        var filePath = System.IO.Path.Combine(path, fileName);

        await using FileStream fs = new FileStream(filePath, FileMode.OpenOrCreate, FileAccess.ReadWrite);
        // fs.Write(smallFileByteArray, 0, smallFileByteArray.Length);
        workbook.Write(fs,true); // 添加 True 保持数据流打开
        workbook.Close(); // 关闭工作簿
        workbook.Dispose(); // 释放工作簿
        // var x = fs.Position;
        // await BlazorDownloadFileService.DownloadFile("存货分类.xlsx", smallFileByteArray, "application/octet-stream");
        await DFS.DownloadFile(fileName, fs, "application/octet-stream"); //可以发送字节，也可以发送流，但是必须发送后关闭流
        fs.Flush();//清除缓冲区
        fs.Close();//关闭
        fs.Dispose();//释放
    }

    public DataTable ToDataTable(List<M.IcInv> entities)
    {
        DataTable dataTable = new DataTable("IcInv");
        M.IcInv t = new M.IcInv();
        PropertyInfo[] properties = t.GetType().GetProperties();// 获得此模型的公共属性

        foreach (PropertyInfo propInfo in properties)
        {   
            if (propInfo.Name == "CategoryName")
            {
                dataTable.Columns.Add(propInfo.Name, typeof(System.String));//
            }
            else
            {
                dataTable.Columns.Add(propInfo.Name, propInfo.PropertyType);
            }
        }

        foreach (M.IcInv entity in entities)
        {
            object[] values = new object[properties.Length];
            for (int i = 0; i < properties.Length; i++)
            {
                if (properties[i].Name == "CategoryName")
                {
                    values[i] = entity.Category.Name;  // 只获取 CategoryName 属性的值
                }
                else
                {
                    values[i] = properties[i].GetValue(entity);
                }
            }
            dataTable.Rows.Add(values);
        }
        return dataTable;
    }


