    private List<InventoryItem> GetIcInvListByInvTrx(List<ITInvInOut> ITInvInOuts)
    {
        List<InventoryItem> Invs = new List<InventoryItem>();
        foreach (ITInvInOut invTrx in ITInvInOuts)
        {
            Invs.Add(invTrx.InventoryItem);
        }
        return Invs;
    }
    private void OnFinish(EditContext editContext)
    {

        Data.TrxType = 1;
        Data.Amount = 0;

        foreach (ITInvInOut invTrx in Data.ITInvInOuts)
        {
            Data.Amount += invTrx.Amount;
            Data.AmountIncTax += invTrx.AmountIncTax;
            Data.Quantity += invTrx.Quantity;
            Data.AmountIncTax = invTrx.AmountIncTax;

            IcPrice icPrice = new IcPrice { InvCode = invTrx.InvCode, Quantity = invTrx.Quantity, Price = invTrx.Price, Amount = invTrx.Amount };

            IcPriceInsertlist.Add(icPrice);
        }
        SqlClient SSC = new SqlClient();
        SSC.Db.UpdateNav(Data)
            .Include(z1 => z1.ITInvInOuts)
            .ExecuteCommand();
        int res;
        res = SSC.Db.Updateable(IcPriceInsertlist).ExecuteCommand();

        IsVisible = false;

        Console.WriteLine($"Success:{JsonSerializer.Serialize(IcPriceInsertlist)}");
    }

