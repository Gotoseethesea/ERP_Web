<PageTitle>库存单据查看</PageTitle>
<!-- 只需要加这一行，模板默认隐藏 -->
<InventoryOrderPrintTemplate @ref="_printTemplateRef" Data="@Data" />

@code{
    // 新增：模板组件引用
    private InventoryOrderPrintTemplate _printTemplateRef;
    private async Task Print()
    {
        if (IsEditing)
        {
            var confirmResult = await ConfirmService.Show("打印确认", "当前单据处于编辑状态，未保存的修改不会被打印，是否继续？", ConfirmButtons.YesNo);
            if (confirmResult != ConfirmResult.Yes) return;
        }

        // 临时显示模板
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('inventory-print-template').style.display = 'block'");
        await Task.Delay(30);

        // 调用你已有的JS打印函数，打印独立模板
        await JSRuntime.InvokeVoidAsync("printElement", "inventory-print-template");

        // 打印完隐藏模板
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('inventory-print-template').style.display = 'none'");
        MessageService.Success("打印已触发");
    }
}

<Row Gutter="16" Align="RowAlign.Middle" Style="margin-bottom: 16px">
    <Col >
        <Title Level="3">库存单据查看</Title>
        <Text Type="TextElementType.Secondary">单据号：@Data.Code</Text>
    </Col>
    <Col>
        <!-- 只有未审核的单据才允许编辑 -->
        <Button Type="ButtonType.Primary"
                OnClick="IcEdit"
                Disabled="@(!string.IsNullOrEmpty(Data.Approver) || IsEditing)">
            编辑
        </Button>
        <Button Type="ButtonType.Default"
                OnClick="Print"
                Style="margin-left: 8px">
            打印 Print()
        </Button>

        <Button @onclick="@(() => PrintService.Print("docs/sample.pdf"))">
            打印PDF
        </Button>
    </Col>
</Row>

<!-- 新增：打印区域包裹 -->
<div id="print-area">
<Form Model="@Data"
      OnFinish="OnFinish"
      OnFinishFailed="OnFinishFailed"
      LabelColSpan="0"
      WrapperColSpan="0">
    <GridRow>
        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="代码">
                <a>@Data.Code</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="分类">
                <a>@Data.TrxGroupCode</a> <a>@Data.TrxGroup.Name</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="日期">
                <a>@Data.Date</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="仓库">
                <a>@Data.WarehouseCode</a><a>@Data.WarehouseName</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="公司">
                <a>@Data.CompanyName</a><a>@Data.CompanyName</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="部门">
                <a>@Data.DepartmentCode</a><a>@Data.DepartmentName</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="职员">
                <a>@Data.EmployeeName</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="8">
            <FormItem Label="摘要">
                <a>@Data.Explanation</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="5">
            <FormItem Label="数量">
                <Statistic Value="@Data.Quantity" Precision="2" Style="margin: 0" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="5">
            <FormItem Label="金额">
                <Statistic Value="@Data.Amount" Precision="2" Style="margin: 0" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="5">
            <FormItem Label="含税金额">
                <Statistic Value="@Data.AmountIncTax" Precision="2" Style="margin: 0" />
            </FormItem>
        </GridCol>
    </GridRow>

</Form>
@if (!IsEditing)
{
