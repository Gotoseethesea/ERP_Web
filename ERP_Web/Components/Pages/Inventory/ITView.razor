else
{
    <Button OnClick="addRow" Type="ButtonType.Primary" Style="margin-bottom:16px" Size="ButtonSize.Small" Disabled=@(!IsEditing)>
        插入行
    </Button>
    <Button OnClick="cancel" Type="ButtonType.Primary" Style="margin-bottom:16px" Size="ButtonSize.Small" Disabled=@(!IsEditing)>
        取消
    </Button>
    <Table DataSource="@Data.ITInvInOuts" TItem="ITInvInOut" Context="row" Size="TableSize.Small"
            ScrollX="1500"
            StickyOffsetHeader="64"
            Resizable
            OnRowClick="@OnRowClick"
            HidePagination Bordered>
        <PropertyColumn Property="c => Data.ITInvInOuts.IndexOf(c) + 1" Title=" " Fixed="ColumnFixPlacement.Left" Width="35"> </PropertyColumn>
        <PropertyColumn Property="c => c.InvCode" Title="存货" Width="120" Fixed="ColumnFixPlacement.Left">
            <Input @bind-Value="@row.InvCode" />
        </PropertyColumn>

        <PropertyColumn Property="c => c.InventoryItem.Name" Title="存货名称" Width="200" Fixed="ColumnFixPlacement.Left">
            <InventorySelector 
                @bind-Value="row.InventoryItem"
                DataSource="@Invs"
                Loading="_loading"
                Placeholder = "@row.InventoryItem?.Name"
                OnSearch="@(async (value) => await InvOnSearch(value))"
                OnSelectedItemChanged="OnSelectedItemChangedHandler" />
        </PropertyColumn>
        <PropertyColumn Property="c => c.Specification.Description" Title="规格" Width="200" Ellipsis>
            <Select DataSource="row.InventoryItem.Specifications"
                    @bind-SelectedItem="row.Specification"
                    @bind-Value="row.Specification"
                    LabelName="@nameof(Specification.Description)"
                    TItemValue="Specification"
                    TItem="Specification"
                    Placeholder="@row.Specification?.Description"
                    ShowArrowIcon="true"
                    SearchDebounceMilliseconds="350"
                    Loading="_loading"
                    OnSelectedItemChanged="@(value => SpeChanged(row,value))">
            </Select>
        </PropertyColumn>
        <PropertyColumn Property="c => c.Specification.Unit" Title="单位" Width="150" Ellipsis>
            @if (row.InventoryItem.Name != null && row.InventoryItem.Name != string.Empty && (row.Specification.Unit == null || row.Specification.Unit == string.Empty))
            {
                <Input @bind-Value="@row.Specification.Unit">
            }
            else
            {
                <a>@row.Specification.Unit</a>
            }
        </PropertyColumn>
        <PropertyColumn Property="c => c.Quantity" Title="数量" Align="ColumnAlign.Right" Width="150">
            <AntDesign.InputNumber @bind-Value="@row.Quantity" Precision="2" Min="0" Bordered="false" @bind-Value:after="() => QuantityChange(row)" Width="140px" />
        </PropertyColumn>
        <PropertyColumn Property="c => c.Price" Title="单价" Align="ColumnAlign.Right" Width="150">
            <AntDesign.InputNumber @bind-Value="@row.Price" Bordered="false" Precision="4" Min="0" AutoSize=1 @bind-Value:after="() => PriceChange(row)" Width="140px" />
        </PropertyColumn>
        <PropertyColumn Property="c => c.Amount" Title="金额" Align="ColumnAlign.Right" Width="150">
            <AntDesign.InputNumber @bind-Value="@row.Amount" Precision="4" Bordered="false" @bind-Value:after="() => PriceChange(row)" Width="140px" />
        </PropertyColumn>
        <PropertyColumn Property="c => c.TaxRate" Title="税率" Align="ColumnAlign.Right" Width="80">
            <AntDesign.InputNumber Step=0.01M Min="0" Max="1" @bind-Value="@row.TaxRate" Bordered="false" @bind-Value:after="() => PriceIncTaxChange(row)" Width="70" />
        </PropertyColumn>
        <PropertyColumn Property="c => c.PriceIncTax" Title="含税单价" Align="ColumnAlign.Right" Width="150">
            <AntDesign.InputNumber @bind-Value="@row.PriceIncTax" Precision="4" Bordered="false" @bind-Value:after="() => PriceIncTaxChange(row)" Width="140px" />
        </PropertyColumn>
        <PropertyColumn Property="c => c.AmountIncTax" Title="含税金额" Align="ColumnAlign.Right" Width="200">
            <AntDesign.InputNumber @bind-Value="@row.AmountIncTax" Precision="4" Bordered="false" @bind-Value:after="() => AmountIncTaxChange(row)" Width="190px" />
        </PropertyColumn>
        <PropertyColumn Property="c => c.Note" Title="备注" Align="ColumnAlign.Center" Ellipsis>
            <AntDesign.Input @bind-Value="@row.Note" Bordered="false" />
        </PropertyColumn>
    </Table>

    <Button Type="@ButtonType.Primary" HtmlType="submit" Disabled=@IsEditing>
        Submit
    </Button>
}
