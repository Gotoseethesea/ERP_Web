    // 刷新数据（修改后）
    private async Task Refresh()
    {
        try
        {
            //_isProcessing = true;
            StateHasChanged();

            // 直接从filterPanel获取条件
            var conModels = filterPanel.GenerateConditionalModels();

            // 查询数据
            SqlClient SSC = new SqlClient();
            Data = await SSC.Db.Queryable<InventoryBalance>()
                .IncludesAllFirstLayer()
                .Where(conModels)
                .ToListAsync();
            StateHasChanged();

            //ShowSuccessModal("刷新成功", "数据已更新");
        }
        catch (Exception ex)
        {
            //ShowErrorModal($"刷新失败: {ex.Message}");
        }
        finally
        {       
            if (!isChecked)
            {
                Data = Data.Where(xx => xx.Quantity != 0).ToList();
            }
            //_isProcessing = false;
            StateHasChanged();
        }
    }

