@code
{
    bool ImageVisible = false;
    string ImageUrl;
    string TrxGroupTemp;
    string Dept;
    string WareH;
    string InvCodeEdit;
    TrxGroup _selectedItem;
    int RowKey;
    int index;

    List<TrxGroup> TrxGroups;
    List<Department> Departments;
    List<Employee> Emps;
    List<Warehouse> Warehouses;
    List<Company> Coms;
    List<InventoryItem> Invs;
    List<IcPrice> IcPrices;
    List<IcPrice> IcPriceInsertlist = new();

    private void SpeChanged(ITInvInOut row, Specification value)
    {
        row.Specification = value;
        string invCode = row.InventoryItem.Code;
        if (value != null)
        {
            row.SKU = value.SKU;
        }

        if (Data.ITInvInOuts.Where(x => x.InvCode is null || x.InvCode == "0").Count() <= 2)
        {
            addRow();
        }
    }
    string SpeDesc = string.Empty;
    private void AddItem(ITInvInOut row, MouseEventArgs args)
    {
        if (!string.IsNullOrWhiteSpace(SpeDesc))
        {
            int newId = row.InventoryItem.Specifications.Count() + 1;
            row.InventoryItem.Specifications.Add(
                new Specification("")
                {
                    Description = SpeDesc,
                    InvCode = row.InventoryItem.Code,
                    IsDefault = false,
                    ConversionRatio = decimal.Zero
                }
            );
            SpeDesc = string.Empty;
        }
    }

    public InventoryTransaction Data = new InventoryTransaction("")
    {
        Date = DateOnly.FromDateTime(DateTime.Now),
        ITInvInOuts = new List<ITInvInOut>()
    };

    protected override void OnInitialized()
    {
        SqlClient SSC = new SqlClient();
        TrxGroups = SSC.Db.Queryable<TrxGroup>().ToList();
        Departments = SSC.Db.Queryable<Models.Department>().ToList();
        Emps = SSC.Db.Queryable<Models.Employee>().ToList();
        Coms = SSC.Db.Queryable<Models.Company>().ToList();
        Warehouses = SSC.Db.Queryable<Models.Warehouse>().ToList();
        Invs = SSC.Db.Queryable<InventoryItem>()
            .IncludesAllFirstLayer()
            .ToList();
        IcPrices = SSC.Db.Queryable<Models.IcPrice>().ToList();

        for (int i = 1; i <= 10; i++)
        {
            Data.ITInvInOuts.Add(new ITInvInOut() { InventoryItem = new InventoryItem() });
        }
    }
    private void OnSelectedItemChangedHandler(InventoryItem value)
    {
        value.Specifications = Specification.Select(value.Code);
        if (value.Specifications == null || !value.Specifications.Any())
        {
            // 处理 Specifications 为 null 或空集合的情况
            Console.WriteLine("Specifications 未找到");
            return;
        }
        Data.ITInvInOuts[index].SKU = value.Specifications.Where(x1 => x1.IsDefault == true).First().SKU;
        Data.ITInvInOuts[index].Specification = value.Specifications.Where(x1 => x1.IsDefault == true).First();
        Data.ITInvInOuts[index].InvCode = value.Code;
        Data.ITInvInOuts[index].InventoryItem = value;
        if (value != null)
        {
            InvCodeEdit = value.Code;
            foreach (ITInvInOut icInvInOut in Data.ITInvInOuts.Where(M => M.InventoryItem.Code != "0" && M.InventoryItem.Name == value.Name))
            {
                icInvInOut.InventoryItem = value;
                icInvInOut.InvCode = value.Code;
                if (Data.TrxType >= 0) //入库单
                {
