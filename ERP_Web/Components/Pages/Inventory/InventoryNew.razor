@page "/inventory_new"
@rendermode InteractiveServer
@inject ModalService ModalService;
@inject ConfirmService ComfirmService;
@using AntDesign
@using AntDesign.TableModels
@using ERP_Web.Components.Custom
@using ERP_Web.Models
@using ERP_Web.Repository
@using SqlSugar
@using System.Text.Json;
@using System.Text.RegularExpressions
@inject IJSRuntime JS
@inject MessageService Message


<div class="center">
    <h3 class="center">单据录入</h3>
</div>

<style>
    .center {
        margin: auto;
        width: 50%;
        padding: 10px;
    }
</style>
<Card>
    <Form Model="@Data"
          OnFinish="OnFinish"
          OnFinishFailed="OnFinishFailed"
          WrapperColSpan="24">
        <GridRow Gutter=@gutter>
            <GridCol Class="gutter-row" Span="6">
                <FormItem Label="代码">
                    <Input Disabled @bind-Value="@context.Code" />
                </FormItem>
            </GridCol>
            <GridCol Class="gutter-row" Span="6" style="width: 180px">
                <FormItem Label="分类">
                    <Select TItem="TrxGroup"
                            TItemValue="string"
                            DataSource="@TrxGroups"
                            @bind-Value="@TrxGroupTemp"
                            ValueName="@nameof(TrxGroup.Name)"
                            LabelName="@nameof(TrxGroup.Name)"
                            GroupName="@nameof(TrxGroup.Note)"
                            SortByLabel="@SortDirection.Ascending"
                            SortByGroup="@SortDirection.Descending"
                            OnSelectedItemChanged="IcTrxGroupChange"
                            Style="width: 100%;">
                    </Select>
                </FormItem>
            </GridCol>
            <GridCol Class="gutter-row" Span="6" style="width: 180px">
                <FormItem Label="日期">
                    <DatePicker @bind-Value="@context.Date" Picker="@DatePickerType.Date" style="width: 180px" />
                </FormItem>
            </GridCol>
            <GridCol Class="gutter-row" Span="6" style="width: 180px">
                <FormItem Label="仓库">
                    <Select TItem="Warehouse"
                            TItemValue="string"
                            DataSource="@Warehouses"
                            @bind-Value="@WareH"
                            ValueName="@nameof(Warehouse.Name)"
                            LabelName="@nameof(Warehouse.Name)"
                            SortByLabel="@SortDirection.Ascending"
                            SortByGroup="@SortDirection.Ascending"
                            OnSelectedItemChanged="WarehouseChange"
                            style="width: 180px">
                    </Select>
                </FormItem>
            </GridCol>
            <GridCol Class="gutter-row" Span="6" >
                <FormItem Label="公司">
                    <Select TItem="Company"
                            TItemValue="Company"
                            DataSource="@Coms"
                            @bind-SelectedItem="@Data.Company"
                            @bind-Value="@Data.Company"
                            LabelName="@nameof(Company.Name)">
                    </Select>
                </FormItem>
            </GridCol>
            <GridCol Class="gutter-row" Span="6" >
                <FormItem Label="部门">
                    <Select TItem="Department"
                            TItemValue="string"
                            DataSource="@Departments"
                            @bind-Value="@Dept"
                            ValueName="@nameof(Department.Name)"
                            LabelName="@nameof(Department.Name)"
                            SortByLabel="@SortDirection.Ascending"
                            SortByGroup="@SortDirection.Ascending"
                            OnSelectedItemChanged="DeptChange"
                            style="width: 180px">
                    </Select>
                </FormItem>
            </GridCol>
            <GridCol Class="gutter-row" Span="6" style="width: 180px">
                <FormItem Label="职员">
                    <Select TItem="Employee"
                            TItemValue="Employee"
                            DataSource="@Emps"
                            @bind-SelectedItem="@Data.Employee"
                            @bind-Value="@Data.Employee"
                            LabelName="@nameof(Employee.Name)"
                            OnSelectedItemChanged="EmpChange"
                            style="width: 180px">
                    </Select>
                </FormItem>
            </GridCol>

            <GridCol Class="gutter-row" Span="8">
                <FormItem Label="摘要">
                    <Input @bind-Value="@context.Explanation" />
                </FormItem>
            </GridCol>
            <GridCol Class="gutter-row" Span="2">
                <VoiceRecognition @ref="voiceRecognition"
                    Id="Explanation"
                    OnResultReceived="HandleRecognitionResultForExp"
                    OnError="HandleRecognitionError"
                    OnEnd="HandleRecognitionEnd"
                    ShowDebugInfo="false" /> <!-- 可选调试模式 -->
            </GridCol>
        </GridRow>

        <GridRow Gutter=@gutter>
            <GridCol Class="gutter-row" Span="5">
                <FormItem Label="总数量">
                    <Statistic Value="@Data.Quantity" Precision="2" Style="margin: 0" />
                </FormItem>
            </GridCol>
            <GridCol Class="gutter-row" Span="5">
                <FormItem Label="金额">
                    <Statistic Value="@Data.Amount" Precision="2" Style="margin: 0" />
                </FormItem>
            </GridCol>
            <GridCol Class="gutter-row" Span="5">
                <FormItem Label="含税金额">
                    <Statistic Value="@Data.AmountIncTax" Precision="2" Style="margin: 0" />
                </FormItem>
            </GridCol>
        </GridRow>
    </Form>
</Card>
@code {
    string style = "background: #0092ff; padding: 8px 0;";
    Dictionary<string, int> gutter = new()
    {
        ["xs"] = 8,
        ["sm"] = 16,
        ["md"] = 24,
        ["lg"] = 32,
        ["xl"] = 48,
        ["xxl"] = 64
    };
}

<!-- 替换原来的顶部/底部重复的GridRow，只保留这一个即可 -->
<GridRow Gutter="16" 
     Align="RowAlign.Middle" 
     Justify="RowJustify.Start"
     Style="margin: 12px 0; min-height: 30px;">
    <!-- 存货选择下拉框 -->
    <GridCol>
        <Select DataSource="@IcInvlist2"
                @bind-Value="@InvName"
                EnableSearch
                EnableVirtualization=true
                ValueName="@nameof(InventoryItem.Name)"
                LabelName="@nameof(InventoryItem.Name)"
                TItemValue="string"
                TItem="InventoryItem"
                Placeholder="@FinalRes"
                ShowArrowIcon="true"
                SearchDebounceMilliseconds="350"
                Loading="_loading"
                OnSearch="@(async (value) => await InvOnSearch(value))"
                OnSelectedItemChanged="OnSelectedItem"
                Style="width: 240px;" />
    </GridCol>

    <!-- 语音识别+按钮组，用flex强制垂直对齐 -->
    <GridCol Style="display: flex; align-items: center; gap: 12px;">
        <VoiceRecognition @ref="voiceRecognition"
            Id="uniqueId"
            OnResultReceived="HandleRecognitionResult"
            OnError="HandleRecognitionError"
            OnEnd="HandleRecognitionEnd"
            ShowDebugInfo="false" />

        <Tag Color="TagColor.Magenta" Style="margin: 0;">@FinalRes</Tag>

        <ButtonGroup>
            <Button OnClick="check" Type="ButtonType.Primary" Size="ButtonSize.Default" Style="margin-left: 8px">语音识别</Button>
            <Button OnClick="addRow" Type="ButtonType.Primary" Size="ButtonSize.Default" Style="margin-left: 8px">插入行</Button>
            <Button OnClick="Submit" Type="@ButtonType.Primary" Size="ButtonSize.Default" Style="margin-left: 8px" HtmlType="submit">提交保存</Button>
        </ButtonGroup>
    </GridCol>

    <GridCol>
        <Select DataSource="@IcInvlist2"
                @bind-Values="@InvNames"
                Mode="SelectMode.Multiple"
                EnableSearch
                EnableVirtualization=true
                ValueName="@nameof(InventoryItem.Name)"
                LabelName="@nameof(InventoryItem.Name)"
                TItemValue="string"
                TItem="InventoryItem"
                Placeholder="可以多选"
                ShowArrowIcon="true"
                SearchDebounceMilliseconds="350"
                Loading="_loading"
                OnSearch="@(async (value) => await InvOnSearch(value))"
                OnSelectedItemChanged="OnSelectedItem"
                Style="width: 240px;" />
    </GridCol>
</GridRow>


<p></p>
<Modal Title="保存" 
    OnOk="@HandleOk"
    OnCancel="@HandleCancel" 
    @bind-Visible="@Modal_visible">
    <p>保存成功</p>
</Modal>
@code {
    // 组件引用
    private VoiceRecognition? voiceRecognition;

    // 处理识别结果
    private Task HandleRecognitionResult(VoiceRecognition.RecognitionResult result)
    {
        // 获取最终识别文本
        string finalText = result.FinalTranscript;

        // 获取完整结构化结果
        var fullResult = result.FullResult;
        FinalRes = finalText;
        InvName = null;
        // 示例：更新表单字段
        //yourFormField = finalText;

        StateHasChanged();  //触发父主键渲染，显示结果@voiceRecognition?.FinalResult
        return Task.CompletedTask;
    }

    private Task HandleRecognitionResultForExp(VoiceRecognition.RecognitionResult result)
    {
        // 获取最终识别文本
        Data.Explanation = result.FinalTranscript;
        StateHasChanged();  //触发父主键渲染，显示结果@voiceRecognition?.FinalResult
        return Task.CompletedTask;
    }

    // 处理识别错误
    private Task HandleRecognitionError(string errorMsg)
    {
        // 示例：显示错误提示
        Console.WriteLine($"语音识别失败: {errorMsg}");
        StateHasChanged();
        return Task.CompletedTask;
    }

    // 处理识别结束
    private Task HandleRecognitionEnd()
    {
        // 示例：执行后续操作
        Console.WriteLine("语音输入完成");
        return Task.CompletedTask;
    }


    // 文件上传成功处理
    private async Task HandleUploadSuccess(UploadFileItem file)
    {
        Message.Success($"{file.FileName} 上传成功", 2);
    }

    // 文件删除成功处理
    private async Task HandleRemoveSuccess(string fileId)
    {
        Message.Success("附件删除成功", 2);
    }
}

