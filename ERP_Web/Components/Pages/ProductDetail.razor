@page "/product-detail/{ProductId}"
@using ERP_Web.Models
@using ERP_Web.Models.PrivilegeHub
@inject NavigationManager NavigationManager
@inject MessageService MessageService
@inject AuthenticationStateProvider AuthProvider


<PageHeader Title="@product.Name" SubTitle="商品详细信息"></PageHeader>
<Button Type="ButtonType.Link" Icon="arrow-left" OnClick="GoBack">返回商品列表</Button>

<Row Gutter="16">
    <Col Span="12">
        <Card Hoverable>
            <Cover>
                <img src="@(product.Image ?? "images/default-product.png")" alt="@product.Name" style="width: 100%; height: 400px; object-fit: contain;" />
            </Cover>
            <Body>
                <Divider />
                <Descriptions Title="属性" Column="1">
                    @foreach (var item in product.Attributes)
                    {
                        <DescriptionsItem Title="@item.Attribute">
                            <RadioGroup @bind-Value="@item.SelectedOptionId" Name="@item.Attribute">
                                @foreach (var o in item.Options)
                                {
                                    <Radio Value="@o.Id"> @o.Value</Radio>
                                }
                            </RadioGroup>
                        </DescriptionsItem>
                    }
                </Descriptions>
                <Button Type="ButtonType.Primary" Icon="shopping-cart" OnClick="@(e => ShowSpecSelector(product, e))">选择规格并加入购物车</Button>
            </Body>
        </Card>
    </Col>
    <Col Span="12">
        <Card Title="商品信息">
            <Body>
                <Descriptions Title="基本信息" Column="1">
                    <DescriptionsItem Title="商品名称">@product.Name</DescriptionsItem>
                    <DescriptionsItem Title="分类">@(product.Category?.Name ?? "未分类")</DescriptionsItem>
                    <DescriptionsItem Title="商品编码">@product.Code</DescriptionsItem>
                    <DescriptionsItem Title="基础价格">
                        ¥ @product.Specifications.FirstOrDefault()?.Options.FirstOrDefault()?.Price
                    </DescriptionsItem>
                </Descriptions>

