@code {
    [Parameter]
    public string ProductId { get; set; } // 从路由获取

    private InventoryItem? product;
    private User user;

    protected override void OnInitialized()
    {
        // 根据 ProductId 加载商品数据
        // 示例：product = InventoryItem.GetById(int.Parse(ProductId));
        // 实际需要调用服务层或数据库
        LoadProductData();
        GetUser();
    }
    public async Task GetUser()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var userCode = authState.User.FindFirst("Account")?.Value;

        user = User.SelectByAccount(userCode);
    }

    private void LoadProductData()
    {
        // TODO: 实现根据 ProductId 加载商品的逻辑
        // 这里用假数据模拟
        product = InventoryItem.Select(ProductId);
        foreach (var item in product.Attributes)
        {
            item.SelectedOptionId = item.Options[0].Id;
        }

        MessageService.Info("测试");

    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/sales/products"); // 或你的商品列表页路由
    }

    private async Task ShowSpecSelector(InventoryItem product, MouseEventArgs e)
    {
        // 这里需要将控制权传回给 ProductSelection 页面来打开模态框
        // 由于跨组件通信较复杂，一个简单方法是提示用户返回列表页操作
        // 更好的方式是利用状态管理或事件总线，这里简化处理

        ShoppingCart shoppingCart = ShoppingCart.GetUserCart(user.Code) ?? new ShoppingCart(user);
        Specification specification = new Specification(product.Code);
        List<InvAttribute> missingAttributes = product.Attributes.Where(x => x.SelectedOptionId != 0).ToList();
        // if (missingAttributes.Count != product.Attributes.Count)
        // {
        //     MessageService.Warning("请选择所有属性的选项");
        //     return;
        // }
        if (missingAttributes.Count == 0) // 没有选择任何属性选项，使用默认规格
        {
            specification = product.Specifications.Where(xx => xx.IsDefault == true).FirstOrDefault() ?? product.Specifications.FirstOrDefault();
            //MessageService.Warning("请选择至少一个属性的选项");
            //return;
        }
        else
        {
            foreach (var item in missingAttributes)
            {
                if (item.SelectedOptionId != 0)
                {
                    specification.Options.Add(item.Options.First(o => o.Id == item.SelectedOptionId));
                }
                // else
                // {
                //     MessageService.Warning($"请选择 {item.Attribute} 的选项");
                //     return;
                // }
            }
            specification.GetDesc();
            specification.Insert();
        }
        //specification = Specification.SelectBySKU(specification.SKU);
        //specification = product.Specifications.Where(xx => xx.IsDefault == true).FirstOrDefault() ?? product.Specifications.FirstOrDefault();

        shoppingCart.Items.Add(new CartItem
        {
            InventoryItem = product,
            InvCode = product.Code,
            Quantity = 1,
            SKU = specification.SKU,
            Price = specification.Options.FirstOrDefault()?.Price ?? 0
        });

        shoppingCart.InsertOrUpdate();

        MessageService.Info("添加购物车成功");
    }
}
