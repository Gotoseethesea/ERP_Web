@page "/PoView/{Text?}"
@rendermode InteractiveServer
@inject ModalService ModalService;
@inject ConfirmService ComfirmService;
@using AntDesign
@using AntDesign.TableModels
@using System.ComponentModel.DataAnnotations
@using ERP_Web.Core.Utilities
@using ERP_Web.Models
@using M = ERP_Web.Models
@using ERP_Web.Repository
@using ERP_Web.Repository.Implement
@using SqlSugar
@using System.Text.Json;

<PageTitle>库存单据查看</PageTitle>
<h3>库存单据查看</h3>

<div>
    <Affix OffsetTop="@_offsetTop">
        <Button Type="ButtonType.Primary" OnClick="PREdit">刷新</Button>
        <Button Type="ButtonType.Primary" OnClick="PREdit">编辑</Button>
        <Button Type="ButtonType.Primary" >提交</Button>
        <Button Type="ButtonType.Primary" OnClick="PRCheck">审批</Button>
        <Button Type="ButtonType.Primary" OnClick="POCreateRe">确认发货</Button>
        <Button Type="ButtonType.Primary" OnClick="AddTop">
            Affix top
        </Button>
    </Affix>
</div>
<Modal Title="@Modal_Title"
       OnOk="@HandleOk"
       OnCancel="@HandleCancel" 
       @bind-Visible="@Modal_visible">
    <p>@Mes</p>
</Modal>
