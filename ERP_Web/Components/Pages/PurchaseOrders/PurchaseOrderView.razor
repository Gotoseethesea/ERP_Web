<Form Model="@Data"
      OnFinish="OnFinish"
      OnFinishFailed="OnFinishFailed"
      LabelColSpan="0"
      WrapperColSpan="0">

    <GridRow gutter="@gutter">
        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="代码">
                <a>@Data.Code</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="分类">
                <a>@Data.PoTrxGroup.Name</a>
            </FormItem>

        </GridCol>
        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="日期">
                <a>@Data.Date</a>
            </FormItem>
        </GridCol>

        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="供应商">
                <a>@Data.Company.Code</a><a>@Data.Company.Name</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="采购部门">
                <a>@Data.Department.Code</a><a>@Data.Department.Name</a>
            </FormItem>
        </GridCol>
    </GridRow>
    <GridRow gutter="@gutter">
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="数量">
                <a>@Data.Quantity</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="  金额  ">
                <a>@Data.Amount</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="  含税金额  ">
                <a>@Data.AmountIncTax</a>
            </FormItem>
        </GridCol>

        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="单据状态">
                <a>@Data.Status</a>
            </FormItem>
        </GridCol>

    </GridRow>
    <GridRow gutter="@gutter">
        <GridCol Class="gutter-row" Span="12">
            <FormItem Label="摘要">
                <a>@Data.Explanation</a>
            </FormItem>
        </GridCol>
    </GridRow>

    <Table DataSource="@Data.POInvInOuts" TItem="M.POInvInOut" Context="row" Size="TableSize.Small" HidePagination Bordered ScrollX="1500" StickyOffsetHeader="64">
        <PropertyColumn Property="c => c.InvCode" Title="代码" ColSpan="1" Width="100px">
        </PropertyColumn>
        <PropertyColumn Property="c => c.InventoryItem.Name" Title="名称" Width="300px">
        </PropertyColumn>
        <PropertyColumn Property="c => c.Specification.Description" Title="规格" Width="300px">
        </PropertyColumn>
        <PropertyColumn Property="c => c.Specification.Unit" Title="单位" Width="50px">
        </PropertyColumn>
        <PropertyColumn Align="ColumnAlign.Right" Property="c => c.Quantity" Title="数量" Width="100px">
            <a> @Math.Round(@row.Quantity, 2)</a>
        </PropertyColumn>
        <PropertyColumn Align="ColumnAlign.Right" Property="c => c.Price" Title="单价" Width="100px">
            <a> @Math.Round(@row.Price, 2)</a>
        </PropertyColumn>
        <PropertyColumn Align="ColumnAlign.Right" Property="c => c.Amount" Title="金额" Width="100px">
            <a> @Math.Round(@row.Amount, 2)</a>
        </PropertyColumn>

        <PropertyColumn Align="ColumnAlign.Right" Property="c => c.TaxRate" Title="税率" Width="100px">
            <a> @Math.Round(@row.TaxRate, 2)</a>
        </PropertyColumn>
        <PropertyColumn Align="ColumnAlign.Right" Property="c => c.PriceIncTax" Title="含税单价" Width="100px">
            <a> @Math.Round(@row.PriceIncTax, 2)</a>
        </PropertyColumn>
        <PropertyColumn Align="ColumnAlign.Right" Property="c => c.Amount" Title="含税金额" Width="100px">
            <a> @Math.Round(@row.Amount, 2)</a>
        </PropertyColumn>
        <PropertyColumn Align="ColumnAlign.Left" Property="c => c.Warehouse" Title="仓库" Width="100px">
            <a> @row.Warehouse?.Name</a>
        </PropertyColumn>

        <SummaryRow>
            <SummaryCell ColSpan="3">Total</SummaryCell>
            <SummaryCell>
                <Text Type="TextElementType.Danger"> </Text>
            </SummaryCell>
            <SummaryCell>
                <Text Type="TextElementType.Danger" style="align-content">@Math.Round(Data.Quantity, 2)</Text>
            </SummaryCell>
            <SummaryCell>
                <Text Type="TextElementType.Danger" style="text-align"></Text>
            </SummaryCell>
            <SummaryCell>
                <Text Type="TextElementType.Danger" style="text-align">@Math.Round(Data.Amount, 2)</Text>
            </SummaryCell>
            <SummaryCell>
                <Text Type="TextElementType.Danger" style="text-align"></Text>
            </SummaryCell>
            <SummaryCell>
                <Text Type="TextElementType.Danger" style="text-align"></Text>
            </SummaryCell>
            <SummaryCell>
                <Text Type="TextElementType.Danger">@Math.Round(Data.AmountIncTax, 2)</Text>
            </SummaryCell>

        </SummaryRow>
        <SummaryRow>
            <SummaryCell>Balance</SummaryCell>
            <SummaryCell ColSpan="2">
                <Text Type="TextElementType.Danger"> 制单人:@Data.Operator </Text>
            </SummaryCell>
            <SummaryCell ColSpan="4">
                <Text Type="TextElementType.Danger"> 审批人:@Data.Checker </Text>
            </SummaryCell>
            <SummaryCell ColSpan="3">
                <Text Type="TextElementType.Danger"> 记账人:@Data.Poster </Text>
            </SummaryCell>
        </SummaryRow>
    </Table>
    <p></p>
    @if (@IsVisible == true)
    {
        <Button OnClick="addRow" Type="ButtonType.Primary" Style="margin-bottom:16px" Size="ButtonSize.Small" Disabled=@Enable>
            插入行
        </Button>
        <Table DataSource="@Data.POInvInOuts" TItem="M.POInvInOut" Context="row" Size="TableSize.Small" RowKey="Row => Row.Id"
               OnRowClick="@OnRowClick"
               Bordered
               Resizable
               HidePagination
               ScrollX="1500" StickyOffsetHeader="64">
            <PropertyColumn Property="c => Data.POInvInOuts.IndexOf(c) + 1" Title=" " Fixed="ColumnFixPlacement.Left" Width="35"> </PropertyColumn>
            <PropertyColumn Property="c => c.InvCode" Title="存货" Width="120" Fixed="ColumnFixPlacement.Left">
                <Input @bind-Value="row.InvCode" />
            </PropertyColumn>
            <PropertyColumn Property="c => c.InventoryItem.Name" Title="存货名称" Width="150" Fixed="ColumnFixPlacement.Left">
                <Select DataSource="@Invs"
                        @bind-SelectedItem="row.InventoryItem"
                        EnableSearch
                        EnableVirtualization=true
                        LabelName="@nameof(M.InventoryItem.Name)"
                        TItemValue="M.InventoryItem"
                        TItem="M.InventoryItem"
                        Placeholder="@(row.InventoryItem?.Name == null ? "输入存货名称" : row.InventoryItem.Name)"
                        ShowArrowIcon="true"
                        HideSelected
                        SearchDebounceMilliseconds="350"
                        Loading="_loading"
                        OnSearch="@(async (value) => await InvOnSearch(value))"
                        OnSelectedItemChanged="OnSelectedItemChangedHandler">
                </Select>
            </PropertyColumn>
            <PropertyColumn Property="c => c.Specification.Description" Title="规格" Width="200" Ellipsis>
                <Select DataSource="row.InventoryItem.Specifications"
                        @bind-SelectedItem="row.Specification"
                        @bind-Value="row.Specification"
                        LabelName="@nameof(M.Specification.Description)"
                        TItemValue="M.Specification"
                        TItem="M.Specification"
                        Placeholder="@(row.Specification.Description == null ? "输入存货名称" : row.Specification.Description)"
                        ShowArrowIcon="true"
                        SearchDebounceMilliseconds="350"
                        Loading="_loading"
                        OnSelectedItemChanged="@(value => SpeChanged(row,value))">
                    <DropdownRender Context="originNode">
                        <div>
                            @originNode
                            <Divider Style="margin: 4px 0"></Divider>
                            <div style="display: flex; flex-wrap: nowrap; padding: 8px">
                                <Input Style="flex: auto" @bind-Value="@SpeDesc" />
                                <a style="flex: none; padding: 8px; display: block; cursor: pointer" @onclick="@(value => AddItem(row, value))">
                                    <Icon Type="@IconType.Outline.Plus" />
                                    Add Item
                                </a>
                            </div>
                        </div>
                    </DropdownRender>
                </Select>
            </PropertyColumn>
            <PropertyColumn Property="c => c.Specification.Unit" Title="单位" Width="150" Ellipsis>
                @if (row.InventoryItem.Name != null && row.InventoryItem.Name != string.Empty && (row.Specification.Unit == null || row.Specification.Unit == string.Empty))
                {
                    <Input @bind-Value="@row.Specification.Unit">
                    }
                    else
                    {
                        <a>@row.Specification.Unit</a>
                    }
                </PropertyColumn>
                <PropertyColumn Property="c => c.Quantity" Title="数量" Align="ColumnAlign.Right" Width="150">
                    <AntDesign.InputNumber @bind-Value="row.Quantity" Precision="2" Min="0" Bordered="false" @bind-Value:after="() => row.QuantityChange()" Width="140px" Style="text-align: right" />
                </PropertyColumn>
                <PropertyColumn Property="c => c.Price" Title="单价" Align="ColumnAlign.Right" Width="150">
                    <AntDesign.InputNumber @bind-Value="row.Price" Bordered="false" Precision="4" Min="0" AutoSize=1 @bind-Value:after="() => row.PriceChange()" Width="140px" />
                </PropertyColumn>
                <PropertyColumn Property="c => c.Amount" Title="金额" Align="ColumnAlign.Right" Width="150">
                    <AntDesign.InputNumber @bind-Value="row.Amount" Precision="4" Bordered="false" @bind-Value:after="() => row.PriceChange()" Width="140px" />
                </PropertyColumn>
                <PropertyColumn Property="c => c.TaxRate" Title="税率" Align="ColumnAlign.Right" Width="80">
                    <AntDesign.InputNumber Step=0.01M Min="0" Max="1" @bind-Value="row.TaxRate" Bordered="false" @bind-Value:after="() => row.PriceIncTaxChange()" Width="70" />
                </PropertyColumn>
                <PropertyColumn Property="c => c.PriceIncTax" Title="含税单价" Align="ColumnAlign.Right" Width="150">
                    <AntDesign.InputNumber @bind-Value="row.PriceIncTax" Precision="4" Bordered="false" @bind-Value:after="() => row.PriceIncTaxChange()" Width="140px" />
                </PropertyColumn>
                <PropertyColumn Property="c => c.AmountIncTax" Title="含税金额" Align="ColumnAlign.Right" Width="200">
                    <AntDesign.InputNumber @bind-Value="row.AmountIncTax" Precision="4" Bordered="false" @bind-Value:after="() => row.AmountIncTaxChange()" Width="190px" />
                </PropertyColumn>

                <PropertyColumn Property="c => c.Warehouse" Title="仓库" Align="ColumnAlign.Right" Width="200">
                    <Select DataSource="Warehouses"
                            @bind-SelectedItem="row.Warehouse"
                            @bind-Value="row.Warehouse"
                            LabelName="@nameof(M.Warehouse.Name)"
                            TItemValue="M.Warehouse"
                            TItem="M.Warehouse"
                            Placeholder="@(row.Warehouse.Name == null ? "选择仓库" : row.Warehouse.Name)"
                            ShowArrowIcon="true"
                            SearchDebounceMilliseconds="350"
                            Loading="_loading"
                            OnSelectedItemChanged="@(value => WarehouseChanged(row,value))">
                    </Select>
                </PropertyColumn>

                <PropertyColumn Property="c => c.Note" Title="备注" Align="ColumnAlign.Center" Ellipsis>
                    <AntDesign.Input @bind-Value="row.Note" Bordered="false" />
                </PropertyColumn>
            </Table>
            <FormItem WrapperColOffset="8" WrapperColSpan="16">
            <Button Type="@ButtonType.Primary" HtmlType="submit" Disabled=@Enable>
                Submit
            </Button>
        </FormItem>
    }
</Form>

