<PageTitle>采购单</PageTitle>
<h3>采购单</h3>
<DynamicButtonGroup PageRoute="PrView" OnButtonClick="HandleButtonClick" />
@code {
    private SqlClient _sqlClient = new();
    private bool _isProcessing = false;

    private async Task HandleButtonClick(string actionName)
    {
        try
        {
            _isProcessing = true;
            StateHasChanged();

            switch (actionName)
            {
                case "Refresh":
                    await RefreshAction();
                    break;
                case "Edit":
                    await EditAction();
                    break;
                case "Submit":
                    await SubmitAction();
                    break;
                case "Approve":
                    await ApproveAction();
                    break;
                case "Reject":
                    await RejectAction();
                    break;
                case "CreatePO":
                    await CreatePOAction();
                    break;
                case "Withdraw":
                    await Withdraw();
                    break;
                default:
                    await HandleCustomAction(actionName);
                    break;
            }
        }
        catch (Exception ex)
        {
            ShowErrorModal($"操作失败: {ex.Message}");
            Console.WriteLine($"{actionName}操作错误: {ex.Message}\n{ex.StackTrace}");
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    // 刷新操作：重新加载数据
    private async Task RefreshAction()
    {
        // 重新加载采购单数据
        Pr = _sqlClient.Db.Queryable<PurchaseRequisition>()
            .IncludesAllFirstLayer()
            .IncludesAllSecondLayer(xc => xc.PRInvInOuts)
            .IncludesAllSecondLayer(xc => xc.ApprovalProcess)
            .IncludesAllSecondLayer(xc => xc.ApprovalType)
            .Includes(xc => xc.ApprovalType, ap => ap.Nodes, ap => ap.Approver)
            .Includes(xc => xc.ApprovalProcess, ap => ap.Steps, ap => ap.ApprovalProcess)
            .Where(it => it.Id == long.Parse(Text))
            .First();

        // 重置编辑状态
        Enable = true;
        IsVisible = false;

        // 加载历史附件
        await LoadAttachments();

        ShowSuccessModal("数据刷新成功");
    }

    // 编辑操作：进入编辑模式
    private async Task EditAction()
    {
        // 初始化关联数据
        foreach (var row in Pr.PRInvInOuts)
        {
            row.Company ??= new Company();
            row.Warehouse ??= new Warehouse();
        }

        // 设置编辑状态
        Enable = false;
        IsVisible = true;

        // 预加载存货数据
        _loading = true;
        Invs = await Task.Run(() => 
            _sqlClient.Db.Queryable<InventoryItem>().ToList());
        _loading = false;

        ShowInfoModal("进入编辑模式", "您现在可以修改采购单内容");
    }

    // 提交操作：提交保存采购单
    private async Task SubmitAction()
    {
        // 验证数据
        if (Pr.PRInvInOuts.Any(r => 
            r.InventoryItem == null || 
            string.IsNullOrEmpty(r.InventoryItem.Code)))
        {
            throw new Exception("存在未选择存货的行项");
        }
        // 保存数据
        Pr.Sumit(_currentUser);

        ShowSuccessModal("提交成功", "采购单已成功提交审批");
    }

    // 审批通过（适配Dictionary返回值）
    private async Task ApproveAction()
    {
        try
        {
            string approveComment = string.Empty;
            // 1. 构建带审批意见输入框的弹窗内容
            RenderFragment content = builder =>
            {
                builder.OpenComponent<Input<string>>(0);
                builder.AddAttribute(1, "Placeholder", "请输入审批意见（选填）");
                builder.AddAttribute(2, "Value", approveComment);
                builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, val => approveComment = val));
                builder.AddAttribute(4, "AutoFocus", true);
                builder.CloseComponent();
            };

            // 2. 弹窗配置
            string _okText = "确认通过";
            string _cancelText = "取消";
            string _title = "请输入审批意见";
            var options = new ConfirmButtonOptions()
            {
                Button1Props = new AntDesign.ButtonProps() { ChildContent = _okText },
                Button2Props = new AntDesign.ButtonProps() { ChildContent = _cancelText }
            };

            // 3. 弹出确认弹窗
            var confirmResult = await _confirmService.Show(
                content,
                _title,
                ConfirmButtons.OKCancel,
                ConfirmIcon.Info,
                options
            );

            if (confirmResult != ConfirmResult.OK)
                return;

            // 4. 调用后端方法，传入审批意见
            Dictionary<bool, string> result = Pr.Approve(_currentUser, approveComment.Trim());

            // 确保你的Pr.Approve方法已经同步改为返回Dictionary<bool, string>，和Reject方法格式一致
            //Dictionary<bool, string> result = Pr.Approve(_currentUser);

            // 方案1：直接判断是否包含成功key（推荐，更安全）
            if (result.ContainsKey(true))
            {
                ShowSuccessModal("审批通过", result[true]);
                await RefreshAction(); // 刷新页面状态
            }
            else
            {
                ShowWarningModal("审批未通过", result[false]);
            }

            // 方案2：取第一个键值对（适合固定只有一个键值对的场景）
            // var res = result.First();
            // if (res.Key)
            // {
            //     ShowSuccessModal("审批通过", res.Value);
            //     await RefreshAction();
            // }
            // else
            // {
            //     ShowWarningModal("审批未通过", res.Value);
            // }
        }
        catch (Exception ex)
        {
            ShowErrorModal($"审批失败: {ex.Message}");
        }
    }

    // 定义成员变量保存选择的退回模式
    private RejectMode _selectedRejectMode = RejectMode.ToDraft;
    private async Task RejectAction()
    {
        try
        {
            string rejectReason = string.Empty;
            string ChildContent1 = string.Empty, ChildContent2 = string.Empty;
            //ChildContent  = $"您选择的退回模式是：{(_selectedRejectMode == RejectMode.ToDraft ? "退回草稿" : "退回上一级")}，请在下方输入拒绝原因并确认。";
            ChildContent1 = $"全部退回（{(_selectedRejectMode == RejectMode.ToDraft ? "✓" : "")} 终止审批流程，修改后重新提交）" ?? "退回草稿";
            ChildContent2 = $"退回上一级（{(_selectedRejectMode == RejectMode.ToPrevious ? "✓" : "")} 退回到上一个审批节点重新审批）" ?? "退回上一级";
            // 1. 弹窗内容：输入框
            RenderFragment content = builder =>
            {
                // builder.OpenComponent<Input<string>>(0);
                // builder.AddAttribute(1, "Placeholder", "请输入拒绝原因（必填）");
                // builder.AddAttribute(2, "Value", rejectReason);
                // builder.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, val => rejectReason = val));
                // builder.AddAttribute(4, "AutoFocus", true);
                // builder.CloseComponent();


                //拒绝原因输入框
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "style", "margin-bottom:16px;");
                builder.OpenComponent<Input<string>>(2);
                builder.AddAttribute(3, "Placeholder", "请输入拒绝原因（必填）");
                builder.AddAttribute(4, "Value", rejectReason);
                builder.AddAttribute(5, "ValueChanged", EventCallback.Factory.Create<string>(this, val => rejectReason = val));
                builder.AddAttribute(6, "AutoFocus", true);
                builder.CloseComponent();
                builder.CloseElement();


                // 退回模式单选组
                builder.OpenElement(10, "div");
                builder.AddAttribute(11, "style", "padding:8px 0;");
                builder.OpenComponent<RadioGroup<RejectMode>>(20);
                builder.AddAttribute(21, "Value", _selectedRejectMode);
                builder.AddAttribute(22, "ValueChanged", EventCallback.Factory.Create<RejectMode>(this, val => _selectedRejectMode = val));
                // 两个选项
                builder.AddAttribute(23, "ChildContent", (RenderFragment)(rb =>
                {
                    rb.OpenComponent<Radio<RejectMode>>(0);
                    rb.AddAttribute(1, "Value", RejectMode.ToDraft);
                    rb.AddAttribute(2, "ChildContent", (RenderFragment)(_xx =>
                    {
                        _xx.AddContent(1, ChildContent1);
                    }));
                    rb.CloseComponent();

                    rb.OpenComponent<Radio<RejectMode>>(1);
                    rb.AddAttribute(1, "Value", RejectMode.ToPrevious);
                    rb.AddAttribute(2, "ChildContent", (RenderFragment)(_xx =>
                      {
                          _xx.AddContent(1, ChildContent2);
                      }));
                    rb.CloseComponent();
                }));
                builder.CloseComponent();
                builder.CloseElement();
            };

            // 2. 弹窗图标
            RenderFragment icon = @<Icon Type="@IconType.Outline.InfoCircle" Style="color:#faad14" />;
            string _okText = "确认拒绝";
            string _cancelText = "取消";
            string _title = "请输入拒绝原因";
            bool _visible = false;
            var options = new ConfirmButtonOptions()
            {
                Button1Props = new AntDesign.ButtonProps()
                {
                    ChildContent = _okText
                },
                Button2Props = new AntDesign.ButtonProps()
                {
                    ChildContent = _cancelText
                }
            };
            // 3. 弹出确认弹窗
            var confirmResult = await
                _confirmService.Show(
                    content,
                    _title,
                    ConfirmButtons.OKCancel,
                    ConfirmIcon.Info
                    ,options
                );

            if (confirmResult != ConfirmResult.OK)
                return;

            // 校验拒绝原因
            if (string.IsNullOrWhiteSpace(rejectReason))
            {
                ShowWarningModal("操作提示", "请输入拒绝原因");
                return;
            }

            // 4. 调用后端方法，传入选择的退回模式
            var result = Pr.Reject(_currentUser, rejectReason.Trim(), _selectedRejectMode);
            if (result.ContainsKey(true))
            {
                ShowSuccessModal("审批拒绝", result[true]);
                await RefreshAction();
            }
            else
            {
                ShowWarningModal("操作失败", result[false]);
            }
        }
        catch (Exception ex)
        {
            ShowErrorModal($"拒绝失败: {ex.Message}");
        }
    }

    // 生成采购订单
    private async Task CreatePOAction()
    {
        if (Pr.Status != DocumentStatus.Approved)
        {
            throw new Exception("只有已审批的采购单才能生成采购订单");
        }
        
        var purchaseOrders = Pr.ConvertToPurchaseOrders();
        
        // 事务处理确保所有订单创建成功
        _sqlClient.Db.Ado.BeginTran();
        try
        {
            foreach (var order in purchaseOrders)
            {
                order.Insert();
            }
            _sqlClient.Db.Ado.CommitTran();
            
            ShowSuccessModal("采购订单已生成", 
                $"成功创建 {purchaseOrders.Count} 个采购订单");
        }
        catch
        {
            _sqlClient.Db.Ado.RollbackTran();
            throw;
        }
    }

    private async Task Withdraw()
    {
        if (Pr.Status != DocumentStatus.Approved)
        {
            throw new Exception("只有已审批的采购单才能生成采购订单");
        }

        var purchaseOrders = Pr.ConvertToPurchaseOrders();

        // 事务处理确保所有订单创建成功
        _sqlClient.Db.Ado.BeginTran();
        try
        {
            foreach (var order in purchaseOrders)
            {
                order.Insert();
            }
            _sqlClient.Db.Ado.CommitTran();

            ShowSuccessModal("采购订单已生成",
                            $"成功创建 {purchaseOrders.Count} 个采购订单");
        }
        catch
        {
            _sqlClient.Db.Ado.RollbackTran();
            throw;
        }
    }


    // 处理自定义操作
    private async Task HandleCustomAction(string actionName)
    {
        // 反射调用对应方法
        var method = GetType().GetMethod($"{actionName}Action");
        if (method != null)
        {
            await (Task)method.Invoke(this, null);
            return;
        }
        
        // 找不到对应方法时提示
        ShowInfoModal("未实现操作", $"'{actionName}'功能尚未实现");
    }

    // 显示模态框的辅助方法
    private void ShowSuccessModal(string title = "操作成功", string message = "")
    {
        Modal_Title = title;
        Mes = string.IsNullOrEmpty(message) ? "操作已成功完成" : message;
        Modal_visible = true;
    }
    private void ShowErrorModal(string message)
    {
        Modal_Title = "操作失败";
        Mes = message;
        Modal_visible = true;
    }
    
    private void ShowWarningModal(string title, string message)
    {
        Modal_Title = title;
        Mes = message;
        Modal_visible = true;
    }
    
    private void ShowInfoModal(string title, string message)
    {
        Modal_Title = title;
        Mes = message;
        Modal_visible = true;
    }
    
    // 加载附件
    private async Task LoadAttachments()
    {
        try
        {
            var attachments = await Http.GetFromJsonAsync<List<SysAttachment>>(
                $"/api/Upload/GetAttachments?refCode={Pr.Code}&refType=PurchaseRequisition");
                
            _defaultFileList = attachments?.Select(a => new UploadFileItem
            {
                Id = a.Id.ToString(),
                FileName = a.Name,
                State = UploadState.Success,
                Url = a.Path
            }).ToList() ?? new List<UploadFileItem>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载附件失败: {ex.Message}");
        }
    }
}

<Modal Title="@Modal_Title"
       OnOk="@HandleOk"
       OnCancel="@HandleCancel"
       @bind-Visible="@Modal_visible">
    <p>@Mes</p>
</Modal>

