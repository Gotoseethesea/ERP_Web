<style>
    /* 附件容器样式 */
    .attachments-container {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    
    /* 文件网格布局 */
    .files-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 8px;
    }
    
    /* 文件卡片样式 */
    .file-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100px;
        padding: 8px;
        border: 1px solid #e8e8e8;
        border-radius: 4px;
        background: #fafafa;
        transition: all 0.3s;
    }
    
