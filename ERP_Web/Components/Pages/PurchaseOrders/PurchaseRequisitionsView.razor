            </FormItem>

        </GridCol>
        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="日期">
                <a>@Pr.Date</a>
            </FormItem>
        </GridCol>

        <GridCol Class="gutter-row" Span="6" style="width: 180px">
            <FormItem Label="部门">
                <a>@Pr.Department.Code</a><a>@Pr.Department.Name</a>
            </FormItem>
        </GridCol>
    </GridRow>
    <GridRow gutter="@gutter">
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="数量">
                <a>@Pr.Quantity</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="  金额  ">
                <a>@Pr.Amount</a>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="  含税金额  ">
                <a>@Pr.AmountIncTax</a>
            </FormItem>
        </GridCol>

        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="单据状态">
                <a>@Pr.GetStatusDisplayName()</a>
            </FormItem>
        </GridCol>

    </GridRow>
    <GridRow gutter="@gutter">
        <GridCol Class="gutter-row" Span="12">
            <FormItem Label="摘要">
                <a>@Pr.Explanation</a>
            </FormItem>
        </GridCol>
    </GridRow>
    <GridRow Gutter=@gutter>
        <GridCol Class="gutter-row" Span="24">
            <FormItem Label="附件">
                <div class="attachments-container">
                    <!-- 文件上传组件 -->
                    <FileUpload RefCode="@Pr.Code"
                                RefType="PurchaseRequisition"
                                OnUploadSuccess="HandleUploadSuccess"
                                OnRemoveSuccess="HandleRemoveSuccess"
                                ShowButton="false"
                                ShowRemoveIcon="false"
                                Disabled="true" />
                
                    <!-- 历史附件展示 -->
                    @if (_defaultFileList.Any())
                    {
                        <div class="files-grid">
                            @foreach (var file in _defaultFileList)
                            {
                                <div class="file-card">
                                    <div class="file-icon-container">
                                        <Icon Type="file" Theme="IconThemeType.Outline" Class="file-icon" />
                                    </div>
                                    <div class="file-name">@file.FileName</div>
                                    <a href="@file.Url" target="_blank" class="download-link">
                                        <Icon Type="download" Theme="IconThemeType.Outline" />
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </FormItem>
        </GridCol>
    </GridRow>

    <GridRow gutter="@gutter">
        @if (Pr.ApprovalProcess != null)
        {
            <GridCol Class="gutter-row" Span="24">
                <!-- 替换原来的审批Steps代码块，直接引入新组件 -->
                <ApprovalOperationTimeline Pr="@Pr" />
            </GridCol>
            <p></p>
        }
        else if (Pr.ApprovalType?.Nodes != null)
        {
