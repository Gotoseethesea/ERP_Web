@page "/PrRecords"
@using AntDesign.TableModels
@using ERP_Web.Components.Custom
@using ERP_Web.Repository
@using M = ERP_Web.Models
@using U = ERP_Web.Core.Utilities

@using System.Text.Json

<PageHeader Title="采购申请记录"></PageHeader>
<Card>
    <FilterPanel @ref="filterPanel"
                 Filters="@Filters"
                 FilterModel="@Pr"
                 gutter="@gutter"
                 OnSearch="Refresh">
    </FilterPanel>
</Card>
@code {
    private List<FilterPanel.FilterItem> Filters = new();
    private FilterPanel filterPanel; // 引用组件实例
    IEnumerable<string> MonthSelected, YearSelected, DeptSelected, WarehSelected;  //选择的月份和年度、仓库
    DateOnly?[] DateOnlys = new DateOnly?[2];
    List<M.Department> Deptlist = M.Department.Select();
    /// <summary>
    /// 设置筛选条件选项--生成筛选条件卡片
    /// </summary>
    private void InitializeFilters()
    {

        // 年份筛选
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "年份",
            Type = FilterPanel.FilterType.Select,
            Options = YearSe.Select(y => new FilterPanel.OptionItem { Value = y, Label = y }).ToList(),
            SelectedValues = YearSelected
        });

        // 月份筛选
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "月份",
            Type = FilterPanel.FilterType.Select,
            Options = MonthSe.Select(m => new FilterPanel.OptionItem { Value = m, Label = m }).ToList(),
            SelectedValues = MonthSelected
        });

        // 日期范围
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "日期范围",
            Type = FilterPanel.FilterType.DateRange,
            DateRange = DateOnlys,
            Span = 12
        });

        // 单号筛选
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "单号",
            Type = FilterPanel.FilterType.Like,
            Placeholder = string.Empty
        });
        // 摘要筛选
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "摘要",
            Type = FilterPanel.FilterType.Like,
            Placeholder = string.Empty
        });

        // 部门筛选
        Filters.Add(new FilterPanel.FilterItem
        {
            Label = "部门",
            Type = FilterPanel.FilterType.Select,
            Options = Deptlist.Select(d => new FilterPanel.OptionItem
            {
                Value = d.Code,
                Label = d.Name
            }).ToList(),
            SelectedValues = DeptSelected
        });

    }
    /// <summary>
    /// 初始化筛选条件范围
    /// </summary>
    public void FiltrateOnInitialized()
    {
        const int min = 1;
        const int max = 12;
        MonthSe = new List<string>();   //月份选项
        YearSe = new List<string>();    //年度选项

        for (var i = min; max >= i; i++)
        {
            var value = Convert.ToString(i);
            var value2 = Convert.ToString(2022 + i);
            MonthSe.Add(value);
            YearSe.Add(value2);
        }
        if (YearSelected == null || YearSelected.Count() == 0)
        {
            YearSelected = new List<string>() { DateTime.Now.Year.ToString() };
        }

        // if (MonthSelected == null || MonthSelected.Count() == 0)
        // {
        //     MonthSelected = new List<string>() { DateTime.Now.Month.ToString() };
        // }
        //Warehouselist = M.Warehouse.Select();
        Deptlist = M.Department.Select();
    }

    /// <summary>
    /// 执行筛选
    /// </summary>
    public void Refresh()
    {
        // 直接从filterPanel获取条件
        var conModels = filterPanel.GenerateConditionalModels();

        // 查询数据
        SqlClient SSC = new SqlClient();
        data = SSC.Db.Queryable<M.PurchaseRequisition>()
            .Includes(y => y.Department)
            .Includes(y => y.Employee)
            .Where(conModels).ToList();
        Console.WriteLine($"search: {RowKey}");
                    StateHasChanged();

    }

    /// <summary>
    /// 初次刷新表格内容
    /// </summary>
    /// <param name="firstRender"></param>
    /// <returns></returns>
    // 把你原来注释的这段代码替换成下面的实现
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 只在页面第一次渲染完成后执行一次
        if (firstRender)
        {
            // 延迟0.5秒执行，确保FilterPanel组件完全初始化完成
            await Task.Delay(500);
            // 确保filterPanel已初始化才执行刷新
            if (filterPanel != null)
            {
                // 调用刷新方法，用InvokeAsync保证UI线程安全
                await InvokeAsync(Refresh);
                //StateHasChanged();

            }
        }
        await base.OnAfterRenderAsync(firstRender);
    }
}

<Card>
    <Table DataSource="@data" TItem="M.PurchaseRequisition" Context="row" Size="TableSize.Small" RowKey="Row => Row.Id"
           OnRowClick="@OnRowClick"
           Resizable
           HidePagination Bordered
           ScrollX="1500" StickyOffsetHeader="64">
        <PropertyColumn Property="c => data.IndexOf(c) + 1" Title=" " Fixed="ColumnFixPlacement.Left" Width="35"> </PropertyColumn>
        <PropertyColumn Property="c => c.TrxNo" Title="单号" Width="120" Fixed="ColumnFixPlacement.Left">
            <a>@row.TrxNo</a>
        </PropertyColumn>
        <PropertyColumn Property="c => c.Date" Title="日期" Width="120" Fixed="ColumnFixPlacement.Left" DefaultSortOrder="SortDirection.Descending">
            <a>@row.Date.ToString()</a>
        </PropertyColumn>
        <PropertyColumn Property="c => c.PRTrxGroupCode" Title="采购类型" Width="120">
            <a>@row.PRTrxGroupCode</a>
        </PropertyColumn>
        <PropertyColumn Property="c => c.Explanation" Title="摘要" Width="150" >
        </PropertyColumn>
        <PropertyColumn Property="c => c.GetStatusDisplayName()" Title=" 状态" Width="150">
        </PropertyColumn>
        <PropertyColumn Property="c => c.DepartmentName" Title="部门" Width="150">
        </PropertyColumn>
        <PropertyColumn Property="c => c.EmployeeName" Title="职员" Width="150">
        </PropertyColumn>
        <PropertyColumn Property="c => c.Quantity" Title="数量" Align="ColumnAlign.Right" Width="150">
            <a>@row.Quantity</a>
        </PropertyColumn>
        <PropertyColumn Property="c => c.Amount" Title="金额" Align="ColumnAlign.Right" Width="150">
        </PropertyColumn>
        <PropertyColumn Property="c => c.AmountIncTax" Title="含税金额" Align="ColumnAlign.Right" Width="150">
        </PropertyColumn>
        <PropertyColumn Property="c => c.InsertUser" Title="操作员" Width="120">
            <a>@row.InsertUser</a>
        </PropertyColumn>
        <PropertyColumn Property="c => c.InsertTime" Title="创建日期" Width="160">
            <a>@row.InsertTime.ToString()</a>
        </PropertyColumn>

        <PropertyColumn Property="c => c.Checker" Title="审批人" Width="120">
            <a>@row.Checker</a>
        </PropertyColumn>
        <PropertyColumn Property="c => c.Active" Title="有效" Width="120">
            <a>@(row.Active == true ? "是" : "否")</a>
        </PropertyColumn>

        <ActionColumn Title="Action" Width="120" Fixed="ColumnFixPlacement.Right">
            <a href="javascript:void(0)" @onclick="() => NavigateToView(row.Id)">查看</a>
            <a @onclick="() => row.Approve()">审批</a>
            <a @onclick="() => row.Delete()">删除</a>
        </ActionColumn>
    </Table>
</Card>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; }

    private void NavigateToView(long id)
    {
        Navigation.NavigateTo($"/PrView/{id}");
    }
}
