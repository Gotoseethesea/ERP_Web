    string Dept;
    string Emp;
    string WareH;
    string InvCodeEdit;
    M.TrxGroup _selectedItem;
    int RowKey = 0;
    int index = 0;
    int i = 0;
    List<M.PoTrxGroup> PoGrouplist;
    List<M.Department> Depts;
    List<M.Warehouse> Wares;
    List<M.Employee> Emps;
    List<M.ApprovalType> AppTypes;
    List<M.IcPrice> IcPricelist;
    List<M.IcPrice> IcPriceInsertlist;
    M.InvTrx InvTrxRowSelected;

    public M.PurchaseRequisition Pr = new M.PurchaseRequisition("")
    {
        Date = DateOnly.FromDateTime(DateTime.Now),
        ApprovalType = new ApprovalType("") { Nodes = new() },
        PRInvInOuts = new List<M.PRInvInOut>() { new PRInvInOut() { Specification = new M.Specification("") } }
    };

    public void PrOnInitialized()
    {
        Pr = new M.PurchaseRequisition("")
        {
            Date = DateOnly.FromDateTime(DateTime.Now),
            PRInvInOuts = new List<M.PRInvInOut>() { new PRInvInOut() { Specification = new M.Specification("") } }
        };
        for (int i = 1; i <= 2; i++)
        {
            Pr.PRInvInOuts.Add(new M.PRInvInOut()
            {
                InventoryItem = new M.InventoryItem("")
                {
                    Specifications = new List<Specification>() {
                        new M.Specification("") }
                },
                Specification = new M.Specification("")
            });

            Pr.PRInvInOuts.Add(new M.PRInvInOut()
            {
                InventoryItem = new M.InventoryItem(""),
                Specification = new M.Specification("")
            });
        }
        Pr.GetTrxNo<PurchaseRequisition>("PR");
        Pr.GetCode("PR");
    }


    protected override void OnInitialized()
    {
        SqlClient SSC = new SqlClient();
        // TrxGrouplist = SSC.Db.Queryable<M.TrxGroup>().ToList();
        PoGrouplist = SSC.Db.Queryable<M.PoTrxGroup>().ToList();
        Depts = SSC.Db.Queryable<Models.Department>().ToList();
        Wares = SSC.Db.Queryable<Models.Warehouse>().ToList();
        Invs = SSC.Db.Queryable<Models.InventoryItem>().IncludesAllFirstLayer().ToList();
        IcPricelist = SSC.Db.Queryable<Models.IcPrice>().ToList();
        Emps = SSC.Db.Queryable<Models.Employee>().ToList();
        AppTypes = SSC.Db.Queryable<Models.ApprovalType>().Includes(x => x.Nodes, y => y.Approver).ToList();

        PrOnInitialized();
        Console.WriteLine($"Success:{JsonSerializer.Serialize(Pr)}");
    }


    public void SpeechConfirmation()
    {
        if (Pr.PRInvInOuts[index].InvCode is not null && RowKey < Pr.PRInvInOuts.Count())
        {
            index++;
            RowKey = index + 1;
            Console.WriteLine("indes:" + index.ToString() + "RowKeys:" + RowKey.ToString());
            Console.WriteLine($"Success:{JsonSerializer.Serialize(Pr.PRInvInOuts[index])}");
        }
        Console.WriteLine("indes:" + index.ToString() + "RowKeys:" + RowKey.ToString());
        Console.WriteLine($"Success:{JsonSerializer.Serialize(Pr.PRInvInOuts[index])}");

        if (FinalRes is not null)
        {
            Inv = Invs.Find(x => x.Name.Contains(FinalRes));
            InvsBySp = Invs.Where(x => x.Name.Contains(FinalRes)).ToList();
            if (InvsBySp == null || InvsBySp.Count() == 0) return;
            var Spe = Inv.Specifications.OrderByDescending(x1 => x1.IsDefault).FirstOrDefault();

            if (Inv is not null)
            {
                Pr.PRInvInOuts[index].InventoryItem = Inv;
                Pr.PRInvInOuts[index].InvCode = Inv.Code;
                Pr.PRInvInOuts[index].Specification = Spe;
            }
            if (RowKey < Pr.PRInvInOuts.Count())
            {
                RowKey = RowKey + 1;
                index = index + 1;
            }
            Console.WriteLine("indes:" + index.ToString() + "RowKeys:" + RowKey.ToString());
            Console.WriteLine($"Success:{JsonSerializer.Serialize(Pr.PRInvInOuts[index])}");
            StateHasChanged();
        }
    }
    private void OnSelectedItem(M.InventoryItem value)
    {
        if (value != null)
        {
            Inv = value;
            if (Pr.PRInvInOuts[index].InvCode is null)
            {
                index--;
                RowKey = index - 1;
            }
            var spe = Inv.Specifications.Find(x1 => x1.IsDefault == true);

            InvCodeEdit = value.Code;
            Pr.PRInvInOuts[index].InventoryItem = value;
            Pr.PRInvInOuts[index].InvCode = value.Code;
            Pr.PRInvInOuts[index].Specification = spe;
        }

    }

    public class ApiResult
    {
