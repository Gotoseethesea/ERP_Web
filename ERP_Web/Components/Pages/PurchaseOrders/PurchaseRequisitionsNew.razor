    List<string> speechToString(string value)
    {
        List<string> res = new List<string>();
        var json = JsonDocument.Parse(value).RootElement;
        var json2 = json.GetProperty("paragraphs");

        foreach (JsonElement je in json2.EnumerateArray())
        {
            var sentences = je.GetProperty("sentences")[1];
            var finalTranscript = sentences.GetProperty("finalTranscript");
            Console.WriteLine($"结果: {finalTranscript.GetString()}");
            if (finalTranscript.GetString() is not null)
                res.Add(finalTranscript.GetString());
        }
        return res;
    }

