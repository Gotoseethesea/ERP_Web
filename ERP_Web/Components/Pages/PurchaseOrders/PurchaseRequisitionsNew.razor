    }

    private void OnSelectedItemChangedHandler(M.InventoryItem value)
    {
        //SqlClient SSC = new SqlClient();
        //M.InventoryBalance inventoryBalance = SSC.Db.Queryable<M.InventoryBalance>().Where(xyz => xyz.InvCode == value.Code).First();


        value.Specifications = M.Specification.Select(value.Code);
