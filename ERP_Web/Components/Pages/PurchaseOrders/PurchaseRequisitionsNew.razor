                                    <Input Style="flex: auto" @bind-Value="@SpeDesc" />
                                    <a style="flex: none; padding: 8px; display: block; cursor: pointer" @onclick="@(value => AddItem(row, value))">
                                        <Icon Type="@IconType.Outline.Plus" />
                                        Add Item
                                    </a>
                                </div>
