@code {
    bool ImageVisible = false;
    string ImageUrl;

    // C# 代码部分
    private RenderFragment GetPrefixIcon(PRInvInOut row) => builder =>
    {
        // 仅当存在图片时才显示图标
        if (!string.IsNullOrEmpty(row.InventoryItem?.Image))
        {
            builder.OpenComponent<Icon>(0);
            builder.AddAttribute(1, "Type", "file-image");
            builder.AddAttribute(2, "Theme", "outline");
            builder.AddAttribute(3, "Style", "cursor: pointer; margin-right: 8px;");
            builder.AddAttribute(4, "OnClick", EventCallback.Factory.Create(this, () =>
            {
                ImageVisible = true;
                ImageUrl = row.InventoryItem?.Image;
            }));
            builder.CloseComponent();
        }
    };

}

@code {
