        {
            // 处理 Specifications 为 null 或空集合的情况
            Console.WriteLine("Specifications 未找到");
            return;
        }
        Pr.PRInvInOuts[index].Specification = value.Specifications.OrderByDescending(x1 => x1.IsDefault).First();
        Pr.PRInvInOuts[index].InventoryItem = value;
        Pr.PRInvInOuts[index].InvCode = value.Code;
        ImageUrl = value.Image;

        if (Pr.PRInvInOuts.Where(x => x.InvCode is null || x.InvCode == "0").Count() <= 2)
        {
            addRow();
        }
    }

