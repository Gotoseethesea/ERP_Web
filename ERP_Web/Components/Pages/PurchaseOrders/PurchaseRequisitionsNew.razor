@page "/PrNew"
@rendermode InteractiveServer
@inject ModalService ModalService;
@inject ConfirmService ConfirmService;
@using AntDesign
@using AntDesign.TableModels
@using System.ComponentModel.DataAnnotations
@using ERP_Web.Components.Custom
@using ERP_Web.Models
@using M = ERP_Web.Models
@using ERP_Web.Repository
@using ERP_Web.Repository.Implement
@using SqlSugar
@using System.Text.Json;
@using AntDesign.JsInterop
@using System.Reflection.Metadata
@using System.Text.RegularExpressions
@inject IJSRuntime JS
@inject MessageService Message

<div class="center">
    <h3 class="center">新增采购申请单</h3>
</div>

<style>
    .center {
        margin: auto;
        width: 50%;
        padding: 10px;
    }
</style>
@code {
    Dictionary<string, int> gutter = new()
    {
        ["xs"] = 8,
        ["sm"] = 16,
        ["md"] = 24,
        ["lg"] = 32,
        ["xl"] = 48,
        ["xxl"] = 64
    };
}
<Form Model="@Pr"
      OnFinish="OnFinish"
      OnFinishFailed="OnFinishFailed"
      LabelColSpan="0"
      WrapperColSpan="20">
    <GridRow Gutter=@gutter>
        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="代码">
                <Input Disabled @bind-Value="Pr.Code" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="单号">
                <Input Disabled @bind-Value="Pr.TrxNo" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="日期">
                <DatePicker @bind-Value="Pr.Date" Picker="@DatePickerType.Date" />
            </FormItem>
        </GridCol>

        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="采购类型">
                <Select TItem="M.PoTrxGroup"
                        TItemValue="M.PoTrxGroup"
                        DataSource="@PoGrouplist"
                        @bind-Value="@Pr.PoTrxGroup"
                        @bind-SelectedItem="@Pr.PoTrxGroup"
                        LabelName="@nameof(M.PoTrxGroup.Name)"
                        GroupName="@nameof(M.PoTrxGroup.Note)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Descending"
                        OnSelectedItemChanged="PoTrxGroupChange"
                        Style="width: 100%;">
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="部门">
                <Select TItem="M.Department"
                        TItemValue="M.Department"
                        DataSource="@Depts"
                        @bind-Value="@Pr.Department"
                        @bind-SelectedItem="@Pr.Department"
                        LabelName="@nameof(M.Department.Name)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Ascending"
                        OnSelectedItemChanged="DeptChange">
                </Select>
            </FormItem>
        </GridCol>

        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="职员">
                <Select TItem="M.Employee"
                        TItemValue="M.Employee"
                        DataSource="@Emps"
                        @bind-Value="@Pr.Employee"
                        @bind-SelectedItem="@Pr.Employee"
                        LabelName="@nameof(M.Employee.Name)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Ascending"
                        OnSelectedItemChanged="EmpChange">
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="6">
            <FormItem Label="审批流程">
                <Select TItem="M.ApprovalType"
                        TItemValue="M.ApprovalType"
                        DataSource="@AppTypes"
                        @bind-Value="@Pr.ApprovalType"
                        @bind-SelectedItem="@Pr.ApprovalType"
                        LabelName="@nameof(M.ApprovalType.Decscription)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Ascending"
                        OnSelectedItemChanged="AppTypeChange">
                </Select>
            </FormItem>
        </GridCol>
    </GridRow>

    <GridRow Align="RowAlign.Middle">
        <GridCol Span="14">
            <FormItem Label="摘要">
                <Input @bind-Value="Pr.Explanation" />
            </FormItem>
        </GridCol>
        <GridCol Span="2">
            <VoiceRecognition @ref="voiceRecognition"
                Id="PrExplanation"
                OnResultReceived="HandleRecognitionResultForExp"
                OnError="HandleRecognitionError"
                OnEnd="HandleRecognitionEnd"
                ShowDebugInfo="false" /> <!-- 可选调试模式 -->
        </GridCol>
    </GridRow>

    <GridRow Gutter=@gutter>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="数量">
                <AntDesign.InputNumber Disabled Precision="2" @bind-Value="@context.Quantity" Width="120" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="金额">
                <AntDesign.InputNumber Disabled Precision="2" @bind-Value="@context.Amount" Width="120" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="含税金额">
                <AntDesign.InputNumber Disabled Precision="4" @bind-Value="@context.AmountIncTax" Width="120" />
            </FormItem>
        </GridCol>
    </GridRow>

    <GridRow Gutter=@gutter>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="附件">
                <FileUpload 
                    RefCode="@Pr.Code" 
                    RefType="PurchaseRequisition"
                    OnUploadSuccess="HandleUploadSuccess"
                    OnRemoveSuccess="HandleRemoveSuccess"/>             
            </FormItem>
        </GridCol>
    </GridRow>


    @if (Pr.ApprovalType?.Nodes != null)
        {
            <GridRow>
                <GridCol Class="gutter-row" Span="@(Pr.ApprovalType?.Nodes?.Count <= 3 ? 14 : 24)">
                    <Steps StartIndex="0" Current="0" Class="site-navigation-steps">
                        @foreach (var node in Pr.ApprovalType?.Nodes ?? Enumerable.Empty<ApprovalNode>())
                        {
                            <Step Title="@node.Role" 
                                Description="@node.Approver?.Name"/>
                        }
                    </Steps>
                </GridCol>
            </GridRow>
        }
</Form>
<style>
  .site-navigation-steps {
      flex-wrap: wrap;
  }
  .site-navigation-steps > .ant-steps-item {
      flex-basis: 20% !important; /* 每行4个 */
      margin-right: 0 !important;
  }
</style>

<GridRow Align="RowAlign.Middle">
    <GridCol Span="4">
        <Select DataSource="@InvsBySp"
                @bind-Value="InvName"
                EnableSearch
                EnableVirtualization=true
                ValueName="@nameof(M.InventoryItem.Code)"
                LabelName="@nameof(M.InventoryItem.Name)"
                TItemValue="string"
                TItem="M.InventoryItem"
                Placeholder="@FinalRes"
                ShowArrowIcon="true"
                HideNotFoundContent="true"
                SearchDebounceMilliseconds="350"
                Loading="_loading"
                OnSearch="@(async (value) => await InvOnSearch(value))"
                OnSelectedItemChanged="OnSelectedItem">
        </Select>
    </GridCol>

    <GridCol Span="2">
        <VoiceRecognition @ref="voiceRecognition"
            Id="uniqueId"
            OnResultReceived="HandleRecognitionResult"
            OnError="HandleRecognitionError"
            OnEnd="HandleRecognitionEnd"
            ShowDebugInfo="false" /> <!-- 可选调试模式 -->

             <Tag Color="TagColor.Magenta">@FinalRes</Tag>
    </GridCol>

    <GridCol Span="2">
        <Button OnClick="SpeechConfirmation">语音识别</Button>
    </GridCol>

    <GridCol Span="4">
        <Button OnClick="addRow" Type="ButtonType.Primary" Size="ButtonSize.Default">
            插入行
        </Button>

        <Button OnClick="Submit" Type="@ButtonType.Primary" Size="ButtonSize.Default" HtmlType="submit">
            提交保存
        </Button>
    </GridCol>
</GridRow>
<p></p>

@code {
    // 组件引用
    private VoiceRecognition? voiceRecognition;

    // 处理识别结果
    private Task HandleRecognitionResult(VoiceRecognition.RecognitionResult result)
    {
        // 获取最终识别文本
        string finalText = result.FinalTranscript;

        // 获取完整结构化结果
        var fullResult = result.FullResult;
        FinalRes = finalText;
        InvName = null;
        // 示例：更新表单字段
        //yourFormField = finalText;
        
        StateHasChanged();  //触发父主键渲染，显示结果@voiceRecognition?.FinalResult
        return Task.CompletedTask;
    }

    private Task HandleRecognitionResultForExp(VoiceRecognition.RecognitionResult result)
    {
        // 获取最终识别文本
        Pr.Explanation = result.FinalTranscript;
        
        StateHasChanged();  //触发父主键渲染，显示结果@voiceRecognition?.FinalResult
        return Task.CompletedTask;
    }
    
    // 处理识别错误
    private Task HandleRecognitionError(string errorMsg)
    {
        // 示例：显示错误提示
        Console.WriteLine($"语音识别失败: {errorMsg}");
        StateHasChanged();
        return Task.CompletedTask;
    }
    
    // 处理识别结束
    private Task HandleRecognitionEnd()
    {
        // 示例：执行后续操作
        Console.WriteLine("语音输入完成");
        return Task.CompletedTask;
    }


        // 文件上传成功处理
    private async Task HandleUploadSuccess(UploadFileItem file)
    {
        Message.Success($"{file.FileName} 上传成功", 2);
    }
    
    // 文件删除成功处理
    private async Task HandleRemoveSuccess(string fileId)
    {
        Message.Success("附件删除成功", 2);
    }
}

<Modal Title="保存"
       OnOk="@HandleOk"
       OnCancel="@HandleCancel"
       @bind-Visible="@Modal_visible">
    <p>保存成功</p>
</Modal>

@if (Pr.PRInvInOuts == null)
