@code {
    // 全局配置，和采购单完全一致
    Dictionary<string, int> gutter = new()
    {
        ["xs"] = 8,
        ["sm"] = 16,
        ["md"] = 24,
        ["lg"] = 32,
        ["xl"] = 48,
        ["xxl"] = 64
    };

    [Parameter]
    public string? Text { get; set; }
    public ReceivingNote RN = new("");
    public List<InventoryItem> Invs = new();
    public List<Warehouse> Warehouses = Warehouse.Select();
    private List<UploadFileItem> _defaultFileList = new();
    public bool Enable = true;
    public bool IsVisible = false;
    bool _loading;

    // 页面初始化，和采购单逻辑完全一致
    protected override async Task OnInitializedAsync()
    {
        // 获取当前登录用户
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var account = user.FindFirst("Account")?.Value;
        if (!string.IsNullOrEmpty(account))
        {
            _currentUser = await _sqlClient.Db.Queryable<User>().FirstAsync(u => u.Account == account);
        }

        // 加载收货单数据
        long id = long.Parse(Text);
        RN = _sqlClient.Db.Queryable<ReceivingNote>()
            .IncludesAllFirstLayer()
            .IncludesAllSecondLayer(xc => xc.RNInvInOuts)
            .Includes(rn => rn.RNInvInOuts, io => io.InventoryItem, inv => inv.Specifications)
            .Where(it => it.Id == id)
            .First();

        // 加载附件
        await LoadAttachments();
    }

    // 编辑模式辅助方法，和采购单逻辑一致
    void addRow()
    {
        RN.RNInvInOuts.Add(new RNInvInOut()
        {
            RNCode = RN.Code,
            Quantity = 0,
            ReceivedQuantity = 0,
            Price = 0,
            TaxRate = 0.13M // 默认税率可修改
        });
        RN.UpdateAmount();
    }

    private void OnSelectedItemChangedHandler(InventoryItem value)
    {
        // 选中存货后自动带出默认规格等逻辑，可按需扩展
    }

    private void OnFinish(EditContext editContext)
    {
        RN.UpdateAmount();
        RN.LastUpdateTime = DateTime.Now;
        RN.Update();
        IsVisible = false;
        ShowSuccessModal("保存成功", "收货单已更新");
    }

    private void OnFinishFailed(EditContext editContext)
    {
        ShowErrorModal("保存失败，请检查输入内容");
    }

    private async Task HandleUploadSuccess(UploadFileItem file)
    {
        Message.Success($"{file.FileName} 上传成功", 2);
        await LoadAttachments();
    }
    
    private async Task HandleRemoveSuccess(string fileId)
    {
        Message.Success("附件删除成功", 2);
        await LoadAttachments();
    }

    // 获取状态标签颜色，和采购单逻辑一致
    private string GetStatusTagColor(DocumentStatus? status)
    {
        return status switch
        {
            DocumentStatus.Draft => "gray",
            DocumentStatus.Submitted or DocumentStatus.Auditing => "blue",
            DocumentStatus.Approved or DocumentStatus.Completed or DocumentStatus.Posted => "green",
            DocumentStatus.Rejected or DocumentStatus.Cancelled or DocumentStatus.Voided => "red",
            _ => "gray"
        };
    }
}
