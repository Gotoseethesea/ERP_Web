@inject CookieEnabledClientFactory CookieClientFactory

<AntDesign.Row Justify="RowJustify.Center" Align="RowAlign.Middle" Style="height:60vh; background-color:#f0f2f5;">
    <AntDesign.Col Span="8">
        <AntDesign.Card Title="系统登录" Style="width:100%;">
            <!-- 修复1：使用NotAuthorized块显示登录表单 -->
            <AuthorizeView Context="authContext">
                <NotAuthorized>
                    <AntDesign.Form Model="userLogin" OnFinish="HandleLogin">
                        <AntDesign.FormItem Label="用户名" Required>
                            <AntDesign.Input @bind-Value="userLogin.Name"  Placeholder="请输入用户名" />
                        </AntDesign.FormItem>
                        <AntDesign.FormItem Label="密码" Required>
                            <AntDesign.InputPassword @bind-Value="userLogin.Password" Placeholder="请输入密码" />
                        </AntDesign.FormItem>
                        <AntDesign.FormItem>
                            <AntDesign.Button Type="ButtonType.Primary" HtmlType="submit" Block>登录</AntDesign.Button>
                        </AntDesign.FormItem>
                    </AntDesign.Form>
                </NotAuthorized>
                <Authorized>
                    <!-- 已登录用户看到的内容 -->
                    <p>您已登录，用户名为：@authContext.User.Identity?.Name</p>
                    <AntDesign.Button Type="ButtonType.Primary" OnClick="GoToHome">进入系统</AntDesign.Button>
                    <AntDesign.Button Type="ButtonType.Primary" OnClick="LoginOut">退出登录</AntDesign.Button>

                </Authorized>
            </AuthorizeView>
        </AntDesign.Card>
    </AntDesign.Col>
</AntDesign.Row>

<Modal Title="操作"
       OnOk="@HandleOk"
       OnCancel="@HandleCancel"
       @bind-Visible="@Modal_visible">
    <p>@Mes</p>
</Modal>


