    // ==================== 数据验证查询 ====================
    public void PrintUserPermissions(long userId)
    {
        SqlClient SSC = new SqlClient();
        var user = SSC.Db.Queryable<User>().InSingle(userId);
        PermissionService permissionService = new PermissionService();
        var permissions = permissionService.GetUserPermissions(user);

        Console.WriteLine($"用户 [{user.Name}] 权限列表：");
        foreach (var perm in permissions.OrderBy(p => p))
