    //初始化数据示例(C#) - 采购单查看页面按钮权限设置
    public class ButtonPermissionInitializer
    {
        public static void Initialize(SqlSugarClient db)
        {
            // 0. 确保表存在
            db.CodeFirst.InitTables<Permission, RolePermission, SysPage, SysButton>();
            
            // 1. 创建采购单查看页面
            var prViewPage = new SysPage
            {
                RouteName = "PrView",
                DisplayName = "采购单查看页面",
                Description = "采购申请单详情查看页面"
            };
            prViewPage.Id = db.Insertable(prViewPage).ExecuteReturnIdentity();
            
            // 2. 创建按钮（对应采购单页面的操作）
            var buttons = new List<SysButton>
            {
                new SysButton {
                    PageId = prViewPage.Id,
                    ButtonCode = "PrView_Refresh",
                    DisplayText = "刷新",
                    ButtonType = "Default",
                    IconType = "reload",
                    OrderIndex = 1,
                    ActionName = "Refresh",
                    PermissionKey = "button:prview:refresh"
                },
                new SysButton {
                    PageId = prViewPage.Id,
                    ButtonCode = "PrView_Edit",
                    DisplayText = "编辑",
                    ButtonType = "Primary",
                    IconType = "edit",
                    OrderIndex = 2,
                    ActionName = "Edit",
                    PermissionKey = "button:prview:edit"
                },
                new SysButton {
                    PageId = prViewPage.Id,
                    ButtonCode = "PrView_Submit",
                    DisplayText = "提交",
                    ButtonType = "Primary",
                    IconType = "check-circle",
                    OrderIndex = 3,
                    ActionName = "Submit",
                    PermissionKey = "button:prview:submit"
                },
                new SysButton {
                    PageId = prViewPage.Id,
                    ButtonCode = "PrView_Approve",
                    DisplayText = "审批",
                    ButtonType = "Success",
                    IconType = "audit",
                    OrderIndex = 4,
                    ActionName = "Approve",
                    PermissionKey = "button:prview:approve"
                },
                new SysButton {
                    PageId = prViewPage.Id,
                    ButtonCode = "PrView_Reject",
                    DisplayText = "拒绝",
                    ButtonType = "Danger",
                    IconType = "close-circle",
                    OrderIndex = 5,
                    ActionName = "Reject",
                    PermissionKey = "button:prview:reject"
                },
                new SysButton {
                    PageId = prViewPage.Id,
                    ButtonCode = "PrView_CreatePO",
                    DisplayText = "生成采购订单",
                    ButtonType = "Primary",
                    IconType = "file-add",
                    OrderIndex = 6,
                    ActionName = "CreatePO",
                    PermissionKey = "button:prview:createpo"
                },
                new SysButton {
                    PageId = prViewPage.Id,
                    ButtonCode = "PrView_Print",
                    DisplayText = "打印",
                    ButtonType = "Default",
                    IconType = "printer",
                    OrderIndex = 7,
                    ActionName = "Print",
                    PermissionKey = "button:prview:print"
                }
            };
            db.Insertable(buttons).ExecuteReturnIdentity();

            // 3. 确保权限存在（如果不存在则创建）
            var permissionKeys = buttons.Select(b => b.PermissionKey).Distinct().ToList();
            var existingPermissions = db.Queryable<Permission>()
                .Where(p => permissionKeys.Contains(p.PermissionKey))
                .ToList();
            
            var newPermissions = permissionKeys
                .Where(key => !existingPermissions.Any(p => p.PermissionKey == key))
                .Select(key => new Permission { PermissionKey = key })
                .ToList();
            
            if (newPermissions.Any())
            {
                db.Insertable(newPermissions).ExecuteCommand();
                existingPermissions = db.Queryable<Permission>()
                    .Where(p => permissionKeys.Contains(p.PermissionKey))
                    .ToList();
            }
            
            // 4. 获取角色（假设这些角色已存在）
            var roles = db.Queryable<Role>().ToList();
            var purchaserRole = roles.First(r => r.Name == "采购主管");
            var approverRole = roles.First(r => r.Name == "库存经理");
            var financeRole = roles.First(r => r.Name == "财务专员");
            var adminRole = roles.First(r => r.Name == "系统管理员");
            
            // 5. 创建角色-按钮权限关联
            var rolePermissions = new List<RolePermission>();
            
            // 采购员权限
            rolePermissions.AddRange(new[]
            {
                CreateRolePermission(purchaserRole.Id, "button:prview:refresh", buttons, existingPermissions),
                CreateRolePermission(purchaserRole.Id, "button:prview:edit", buttons, existingPermissions),
                CreateRolePermission(purchaserRole.Id, "button:prview:submit", buttons, existingPermissions),
                CreateRolePermission(purchaserRole.Id, "button:prview:print", buttons, existingPermissions)
            });
            
            // 审批员权限
            rolePermissions.AddRange(new[]
            {
                CreateRolePermission(approverRole.Id, "button:prview:refresh", buttons, existingPermissions),
                CreateRolePermission(approverRole.Id, "button:prview:approve", buttons, existingPermissions),
                CreateRolePermission(approverRole.Id, "button:prview:reject", buttons, existingPermissions),
                CreateRolePermission(approverRole.Id, "button:prview:print", buttons, existingPermissions)
            });
            
            // 财务权限
            rolePermissions.AddRange(new[]
            {
                CreateRolePermission(financeRole.Id, "button:prview:refresh", buttons, existingPermissions),
                CreateRolePermission(financeRole.Id, "button:prview:print", buttons, existingPermissions),
                CreateRolePermission(financeRole.Id, "button:prview:createpo", buttons, existingPermissions)
            });
            
            // 管理员拥有所有权限
            foreach (var button in buttons)
            {
                rolePermissions.Add(CreateRolePermission(
                    adminRole.Id,
                    button.PermissionKey,
                    buttons,
                    existingPermissions));
            }
            
            // 插入角色权限
            db.Insertable(rolePermissions).ExecuteCommand();
        }
        
        private static RolePermission CreateRolePermission(
            int roleId,
            string permissionKey,
            List<SysButton> buttons,
            List<Permission> permissions)
        {
            var permission = permissions.First(p => p.PermissionKey == permissionKey);
            var button = buttons.First(b => b.PermissionKey == permissionKey);
            
            return new RolePermission
            {
                RoleId = roleId,
                PermissionId = permission.Id,
                ButtonId = button.Id
            };
        }
    }
    // ==================== 性能优化建议 ====================
    /*
    1. 数据库层优化：
       - 添加索引：ParentId, Active, Sequence
       - 使用缓存：菜单数据变动频率低，适合缓存

    2. 前端优化：
       - 实现按需加载：只加载当前可见菜单
       - 本地存储权限信息，避免重复请求

    3. 权限检查优化：
       - 预生成权限树，减少实时计算
       - 使用位运算加速权限检查
    */
}


    