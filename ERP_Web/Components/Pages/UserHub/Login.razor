<!-- 全屏渐变背景，和模块选择页风格统一 -->
<div style="min-height: 100vh; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; padding: 20px;">
    <!-- 响应式容器：大屏左右分栏，小屏上下堆叠 -->
    <div style="width: 100%; max-width: 1000px; background: #fff; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); overflow: hidden; display: flex; flex-wrap: wrap;">
        <!-- 左侧品牌区：大屏占60%，小屏隐藏/缩成顶部 -->
        <div style="flex: 1 1 60%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 60px 40px; color: #fff; display: flex; flex-direction: column; justify-content: center; min-height: 400px;">
            <div style="margin-bottom: 40px;">
                <Icon Type="cloud-server" Style="font-size: 64px; margin-bottom: 16px; opacity: 0.9;" />
                <Title Level="2" Style="color: #fff; margin: 0 0 8px 0;">ERP管理系统</Title>
                <Text Style="color: rgba(255,255,255,0.85); font-size: 16px;">企业数字化管理平台</Text>
            </div>
            <div style="margin-top: auto;">
                <Text Style="color: rgba(255,255,255,0.7); display: block; margin-bottom: 8px;">✅ 进销存管理</Text>
                <Text Style="color: rgba(255,255,255,0.7); display: block; margin-bottom: 8px;">✅ 人事管理</Text>
                <Text Style="color: rgba(255,255,255,0.7); display: block;">✅ 审批工作流</Text>
            </div>
        </div>

        <!-- 右侧登录表单区：大屏占40%，小屏占100% -->
        <div style="flex: 1 1 40%; padding: 60px 40px; display: flex; flex-direction: column; justify-content: center;">
            <div style="text-align: center; margin-bottom: 32px;">
                <Title Level="3" Style="margin: 0 0 8px 0; color: #1f1f1f;">欢迎登录</Title>
                <Text Type="TextElementType.Secondary">请输入您的账号密码</Text>
            </div>

            <AuthorizeView Context="authContext">
                <NotAuthorized>
                    <AntDesign.Form Model="userLogin" OnFinish="HandleLogin" Layout="FormLayout.Vertical">
                        <AntDesign.FormItem Label="用户名" Required Style="margin-bottom: 20px;">
                            <AntDesign.Input @bind-Value="userLogin.Name"
                                             Placeholder="请输入用户名"
                                             Size="InputSize.Large"
                                             PrefixIcon="user"
                                             AutoComplete="true" />
                        </AntDesign.FormItem>
                        <AntDesign.FormItem Label="密码" Required Style="margin-bottom: 24px;">
                            <AntDesign.InputPassword @bind-Value="userLogin.Password"
                                                     Placeholder="请输入密码"
                                                     Size="InputSize.Large"
                                                     AutoComplete="true" />
                        </AntDesign.FormItem>
                        <AntDesign.FormItem Style="margin-bottom: 0;">
                            <AntDesign.Button Type="ButtonType.Primary"
                                              HtmlType="submit"
                                              Block
                                              Size="ButtonSize.Large">
                                立即登录
                            </AntDesign.Button>
                        </AntDesign.FormItem>
                    </AntDesign.Form>
                </NotAuthorized>
                <Authorized>
                    <div style="text-align: center;">
                        <Avatar Size="AvatarSize.Large" Icon="user" Style="margin-bottom: 16px; background: #1890ff;" />
                        <Text Strong Style="font-size: 16px; display: block; margin-bottom: 8px;">@authContext.User.Identity?.Name</Text>
                        <Text Type="TextElementType.Secondary" Style="display: block; margin-bottom: 24px;">您已登录系统</Text>
                        <Space Size="SpaceSize.Middle" Direction="SpaceDirection.Vertical" Style="width: 100%;">
                            <AntDesign.Button Type="ButtonType.Primary" OnClick="GoToHome" Block Size="ButtonSize.Large">进入系统</AntDesign.Button>
                            <AntDesign.Button OnClick="LoginOut" Block Size="ButtonSize.Large">退出登录</AntDesign.Button>
                        </Space>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>



<Modal Title="操作"
       OnOk="@HandleOk"
       OnCancel="@HandleCancel"
       @bind-Visible="@Modal_visible">
