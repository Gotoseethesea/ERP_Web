<script>
    // 设置单个 Cookie
    window.setCookie = function (name, value, options = {}) {
        const {
            expires,
            path = '/',
            domain = window.location.hostname,
            secure = true,
            sameSite = 'Lax'
        } = options;

        let cookieStr = `${encodeURIComponent(name)}=${encodeURIComponent(value)}`;

        if (expires) cookieStr += `; expires=${expires.toUTCString()}`;
        if (path) cookieStr += `; path=${path}`;
        if (domain) cookieStr += `; domain=${domain}`;
        if (secure) cookieStr += '; Secure';
        if (sameSite) cookieStr += `; SameSite=${sameSite}`;

        document.cookie = cookieStr;
        return true;
    };

    // 批量设置 Cookies
    window.setCookies = function (cookies) {
        cookies.forEach(cookie => {
            window.setCookie(
                cookie.name,
                cookie.value,
                {
                    expires: cookie.expires ? new Date(cookie.expires) : null,
                    path: cookie.path,
                    domain: cookie.domain,
                    secure: cookie.secure,
                    sameSite: cookie.sameSite
                }
            );
        });
        return cookies.length;
    };
    // 增强版 setCookie 函数
    window.setCookieStr = function (cookie) {
        let cookieStr = `${encodeURIComponent(cookie.name)}=${encodeURIComponent(cookie.value)}`;

        if (cookie.expires) {
            cookieStr += `; expires=${new Date(cookie.expires).toUTCString()}`;
        }
        if (cookie.path) {
            cookieStr += `; path=${cookie.path}`;
        }
        if (cookie.domain) {
            cookieStr += `; domain=${cookie.domain}`;
        }
        if (cookie.secure) {
            cookieStr += '; Secure';
        }
        if (cookie.sameSite) {
            cookieStr += `; SameSite=${cookie.sameSite}`;
        }

        document.cookie = cookieStr;
        return true;
    };
    window.deleteCookie = function (name, options = {}) {
        const {
            path = '/',
            domain = window.location.hostname
        } = options;

        // 构建 Cookie 删除字符串
        let cookieStr = `${encodeURIComponent(name)}=`;

        // 设置过期时间为过去（1970年1月1日）
        cookieStr += '; expires=Thu, 01 Jan 1970 00:00:00 GMT';

        // 添加路径和域信息
        if (path) cookieStr += `; path=${path}`;
        if (domain) cookieStr += `; domain=${domain}`;

        // 尝试设置 Cookie
        try {
            document.cookie = cookieStr;
            console.error(`删除 Cookie "${name}" 成功:`, cookieStr);

            return true;
        } catch (error) {
            console.error(`删除 Cookie "${name}" 失败:`, error);
            return false;
        }
    };
</script>

@code {
    @inject IJSRuntime JsRuntime

    @inject IHttpClientFactory HttpClientFactory

    private async Task SyncCookiesToBrowser()
    {
        // 1. 获取 HttpClient 实例
        var httpClient = HttpClientFactory.CreateClient("CookieEnabledClient");

        // 2. 获取关联的 CookieContainer
        var handler = GetHandler(httpClient);
        if (handler?.CookieContainer == null) return;

        // 3. 获取所有 Cookie
        var uri = new Uri("https://localhost:9000");
        var cookieCollection = handler.CookieContainer.GetCookies(uri);

        // 4. 转换为 JS 可序列化对象
        var cookiesToSync = new List<object>();
        foreach (Cookie cookie in cookieCollection)
        {
            cookiesToSync.Add(new
            {
                name = cookie.Name,
                value = cookie.Value,
                expires = cookie.Expires != DateTime.MinValue ? cookie.Expires : (DateTime?)null,
                path = cookie.Path,
                domain = cookie.Domain,
                secure = cookie.Secure,
                //sameSite = cookie.SameSite.ToString() // None/Lax/Strict
                sameSite = "Lax"
            });
        }

        // 5. 调用 JS 写入浏览器
        if (cookiesToSync.Count > 0)
        {
            await JsRuntime.InvokeVoidAsync("setCookies", cookiesToSync);
            Console.WriteLine($"已同步 {cookiesToSync.Count} 个 Cookie 到浏览器");
        }
    }

    // 辅助方法：获取 HttpClient 的底层 Handler
    private HttpClientHandler GetHandler(HttpClient httpClient)
    {
        var handlerField = typeof(HttpMessageInvoker).GetField(
            "_handler",
            System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic
        );

        return handlerField?.GetValue(httpClient) as HttpClientHandler;
    }

}

