@code {
    private User userLogin = new User();

    // 在组件初始化时订阅事件
    //ServerAuthenticationStateProvider serverAuth;
    protected override void OnInitialized()
    {
        if (AuthStateProvider is ServerAuthenticationStateProvider s)
        {
            s.AuthenticationStateChanged += HandleAuthStateChanged;
        }
    }

    private void HandleAuthStateChanged(Task<AuthenticationState> authState)
    {
        // 处理状态变更逻辑（如更新UI）
        StateHasChanged(); // 通知组件重新渲染
    }

    // 组件销毁时取消订阅
    public void Dispose()
    {
        if (AuthStateProvider is ServerAuthenticationStateProvider s)
        {
            s.AuthenticationStateChanged -= HandleAuthStateChanged;
        }
    }
    private void GoToHome() => NavigationManager.NavigateTo("/");

    private async Task HandleLogin()
    {
        if (!string.IsNullOrEmpty(userLogin.Name) && !string.IsNullOrEmpty(userLogin.Password))
        {
            try
            {
                var (httpClient, cookieContainer) = CookieClientFactory.CreateCookieEnabledClient("CookieEnabledClient");

                var form = new Dictionary<string, string>
                {
                    ["name"] = userLogin.Name ?? string.Empty,
                    ["password"] = userLogin.Password ?? string.Empty
                };
                var content = new FormUrlEncodedContent(form);

                // 👇 关键1：用当前页面访问地址构造请求地址，自动适配IP/localhost
                var currentBaseUri = new Uri(NavigationManager.BaseUri);
                var resp = await httpClient.PostAsync(new Uri(currentBaseUri, "/loginApi"), content);

                if (resp.IsSuccessStatusCode)
                {
                    if (cookieContainer == null) return;

                    // 👇 关键2：动态获取当前访问域名，不再写死localhost
                    var currentUri = new Uri(NavigationManager.Uri);
                    var cookieCollection = cookieContainer.GetCookies(currentUri);

                    var cookiesToSync = new List<object>();
                    foreach (Cookie cookie in cookieCollection)
                    {
                        cookiesToSync.Add(new
                        {
                            name = cookie.Name,
                            value = cookie.Value,
                            expires = cookie.Expires != DateTime.MinValue ? cookie.Expires : (DateTime?)null,
                            path = cookie.Path,
                            // 👇 关键3：Cookie的Domain强制设为当前访问的域名，适配IP
                            domain = currentUri.Host,
                            secure = currentUri.Scheme == "https",
                            sameSite = "Lax"
                        });
                    }

                    if (cookiesToSync.Count > 0)
                    {
                        await JsRuntime.InvokeVoidAsync("setCookies", cookiesToSync);
                    }

                    NavigationManager.NavigateTo("/", forceLoad: true);
                }
                else if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    Mes = "登录失败：用户名或密码错误";
                    Modal_visible = true;
                }
                else
                {
                    Mes = $"登录失败：{resp.StatusCode}";
                    Modal_visible = true;
                }
            }
            catch (Exception ex)
            {
                // 捕获所有异常，避免Circuit断开
                Mes = $"登录异常：{ex.Message}";
                Modal_visible = true;
            }
        }
    }
    private async Task LoginOut()
    {
        try
        {
            var (httpClient, cookieContainer) = CookieClientFactory.CreateCookieEnabledClient("CookieEnabledClient");
            var currentBaseUri = new Uri(NavigationManager.BaseUri);
            var resp = await httpClient.PostAsync(new Uri(currentBaseUri, "api/Account/logout"), null);

            if (resp.IsSuccessStatusCode)
            {
                // 删除Cookie时用当前域名
                await JsRuntime.InvokeVoidAsync("deleteCookie", "ERP.Auth", new { domain = new Uri(NavigationManager.Uri).Host });
                NavigationManager.NavigateTo("/", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            Mes = $"登出异常：{ex.Message}";
            Modal_visible = true;
        }
    }

