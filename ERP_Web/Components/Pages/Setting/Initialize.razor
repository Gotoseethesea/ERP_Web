                    Remark = "专业财务管理系统的通用缩写，比ERP自带的基础财务模块覆盖更深，包含总账核算、预算管控、资金池管理、成本分析、税务合规、多准则报表生成等功能；集团企业、上市公司核心业务系统",
                    Icon = "account-book",
                    SortOrder = 7
                },
                new SystemBusinessModule
                {
                    Code = "EMS",
                    Name = "工程能耗管理系统",
                    Abbreviation = "EMS",
                    FullEnglishName = "Energy Management System",
                    Description = "项目管理、进度跟踪、工单管理、物料核算",
                    Style = "font-size:64px;color:#13c2c2;margin-bottom:16px",
                    Remark = "面向工业工程、工厂、园区、建筑的能耗（水、电、气、热等）全流程管理标准缩写，覆盖能耗数据采集、实时监测、能效分析、节能优化、碳排放核算等功能；高能耗行业通用",
                    Icon = "tool",
                    SortOrder = 8
                }
            };

            // ====================== 4. 去重批量插入（仅插入不存在的缩写） ======================
            Db.DbMaintenance.TruncateTable<SystemBusinessModule>();

            var existsAbbrs = Db.Queryable<SystemBusinessModule>().Select(it => it.Abbreviation).ToList();
            var waitInsertList = systemList.Where(it => !existsAbbrs.Contains(it.Abbreviation)).ToList();

            if (waitInsertList.Any())
            {

                var insertCount = Db.Insertable(waitInsertList).ExecuteCommand();
                Console.WriteLine($"插入成功，共新增 {insertCount} 条系统数据");
            }
            else
            {
                Console.WriteLine("所有系统数据已存在，无需重复插入");
            }

            // ====================== 5. 验证插入结果 ======================
            var allData = Db.Queryable<SystemBusinessModule>().OrderBy(it => it.SortOrder).ToList();
            Console.WriteLine("\n当前表内所有系统数据：");
            foreach (var item in allData)
            {
                Console.WriteLine($"{item.SortOrder}. {item.Name} ({item.Abbreviation})");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"操作失败：{ex.Message}");
        }
    }
