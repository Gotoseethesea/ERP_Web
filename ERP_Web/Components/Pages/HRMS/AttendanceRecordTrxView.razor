@page "/hr/attendance/record"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AntDesign.TableModels
@using ERP_Web.Models
@using ERP_Web.Repository
@using ERP_Web.Core.Utilities
@using System.Text.Json

<h3>打卡记录</h3>
<Form Model="@FilterModel">
    <GridRow gutter="@gutter">
        <GridCol Span="6">
            <FormItem Label="部门">
                <Select Mode="SelectMode.Multiple"
                        Placeholder="请选择部门"
                        @bind-Values="@DeptSelected"
                        TItemValue="string"
                        TItem="string"
                        EnableSearch
                        AllowClear>
                    <SelectOptions>
                        @foreach (var item in Deptlist)
                        {
                            <SelectOption TItemValue="string" TItem="string" Value=@item.Code Label=@item.Name />
                        }
                    </SelectOptions>
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="考勤状态">
                <Select Mode="SelectMode.Default"
                        Placeholder="请选择状态"
                        @bind-Value="@StatusFilter"
                        TItemValue="int?"
                        TItem="int?"
                        AllowClear>
                    <SelectOption TItemValue="int?" TItem="int?" Value="null" Label="全部" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="0" Label="正常" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="1" Label="迟到" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="2" Label="早退" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="3" Label="旷工" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="4" Label="请假" />
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="考勤日期">
                <RangePicker TValue="DateOnly?[]" Format="yyyy-MM-dd" @bind-Value="DateOnlys" />
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="员工姓名">
                <Input @bind-Value="@Keyword" Placeholder="请输入员工姓名" />
            </FormItem>
        </GridCol>
        <GridCol Span="2">
            <Button OnClick="Refresh" Icon="@IconType.Outline.Search" Type="@ButtonType.Primary" HtmlType="button">
                搜索
            </Button>
        </GridCol>
    </GridRow>
</Form>

<Table DataSource="@data" TItem="AttendanceRecord" Context="row" Size="TableSize.Small" RowKey="Row => Row.Id"
       Resizable
       HidePagination Bordered
       ScrollX="1800" StickyOffsetHeader="64">
    <PropertyColumn Property="c => c.Employee.Name" Title="员工姓名" Width="100" Fixed="ColumnFixPlacement.Left">
        @row.Employee?.Name ?? "-"
    </PropertyColumn>
    <PropertyColumn Property="c => c.Employee.Code" Title="工号" Width="100">
        @row.Employee?.Code ?? "-"
    </PropertyColumn>
    <PropertyColumn Property="c => c.Employee.Name" Title="部门" Width="120">
        @row.Employee?.Department?.Name ?? "-"
    </PropertyColumn>
    <PropertyColumn Property="c => c.AttendanceDate" Title="考勤日期" Width="120">
        @row.AttendanceDate.ToString("yyyy-MM-dd")
    </PropertyColumn>
    <PropertyColumn Property="c => c.CheckInTime" Title="上班打卡" Width="120">
        @row.CheckInTime?.ToString("HH:mm:ss") ?? "-"
    </PropertyColumn>
    <PropertyColumn Property="c => c.CheckOutTime" Title="下班打卡" Width="120">
        @row.CheckOutTime?.ToString("HH:mm:ss") ?? "-"
    </PropertyColumn>
    <PropertyColumn Property="c => c.WorkHours" Title="工作时长" Width="100" Align="ColumnAlign.Right">
        @row.WorkHours.ToString("0.0")h
    </PropertyColumn>
    <ActionColumn Title="状态" Width="100">
        <Tag Color="@(row.Status switch {
            0 => "green",
            1 or 2 => "orange",
            3 or 4 => "red",
            _ => "default"
        })">
            @row.GetStatusDisplayName()
        </Tag>
    </ActionColumn>
    <PropertyColumn Property="c => c.Remark" Title="备注" Width="150" />
    <PropertyColumn Property="c => c.InsertTime" Title="创建时间" Width="160" />

    <ActionColumn Title="操作" Width="150" Fixed="ColumnFixPlacement.Right">
        <Space Size="SpaceSize.Small">
            <Button Type="ButtonType.Link" Size="ButtonSize.Small">编辑</Button>
            <Button Type="ButtonType.Link" Size="ButtonSize.Small" Danger>删除</Button>
        </Space>
    </ActionColumn>
</Table>

@code {
    List<Department> Deptlist = Department.Select();
    IEnumerable<string> DeptSelected;
    DateOnly?[] DateOnlys = new DateOnly?[2];
    int? StatusFilter;
    string Keyword;
    AttendanceRecord FilterModel = new AttendanceRecord();

    Dictionary<string, int> gutter = new()
    {
        ["xs"] = 8,
        ["sm"] = 16,
        ["md"] = 24,
        ["lg"] = 32,
        ["xl"] = 48,
        ["xxl"] = 64
    };

    List<AttendanceRecord> data = new List<AttendanceRecord>();

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    public async Task Refresh()
    {
        try
        {
            SqlClient SSC = new SqlClient();
            var query = SSC.Db.Queryable<AttendanceRecord>()
                .Includes(a => a.Employee, e => e.Department)
                .Where(a => a.Active);

            // 部门筛选
            if (DeptSelected != null && DeptSelected.Any())
            {
                var deptIds = Deptlist.Where(d => DeptSelected.Contains(d.Code)).Select(d => d.Code).ToList();
                query = query.Where(a => deptIds.Contains(a.Employee.DepartmentCode));
            }

            // 状态筛选
            if (StatusFilter.HasValue)
            {
                query = query.Where(a => a.Status == StatusFilter.Value);
            }

            // 日期筛选
            if (DateOnlys[0].HasValue)
            {
                query = query.Where(a => a.AttendanceDate >= DateOnlys[0].Value.ToDateTime(TimeOnly.MinValue));
            }
            if (DateOnlys[1].HasValue)
            {
                query = query.Where(a => a.AttendanceDate <= DateOnlys[1].Value.ToDateTime(TimeOnly.MaxValue));
            }

            // 姓名筛选
            if (!string.IsNullOrEmpty(Keyword))
            {
                query = query.Where(a => a.Employee.Name.Contains(Keyword));
            }

            data = await query.OrderByDescending(a => a.AttendanceDate).ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"查询打卡记录失败：{ex.Message}");
            data = new List<AttendanceRecord>();
        }
    }
}
