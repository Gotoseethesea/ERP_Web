@page "/hr/recruitment/plan"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AntDesign.TableModels
@using ERP_Web.Models
@using ERP_Web.Repository
@using ERP_Web.Core.Utilities
@using System.Text.Json

<h3>招聘计划</h3>
<Form Model="@FilterModel">
    <GridRow gutter="@gutter">
        <GridCol Span="6">
            <FormItem Label="部门">
                <Select Mode="SelectMode.Multiple"
                        Placeholder="请选择部门"
                        @bind-Values="@DeptSelected"
                        TItemValue="string"
                        TItem="string"
                        EnableSearch
                        AllowClear>
                    <SelectOptions>
                        @foreach (var item in Deptlist)
                        {
                            <SelectOption TItemValue="string" TItem="string" Value=@item.Code Label=@item.Name />
                        }
                    </SelectOptions>
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="状态">
                <Select Mode="SelectMode.Default"
                        Placeholder="请选择状态"
                        @bind-Value="@StatusFilter"
                        TItemValue="int?"
                        TItem="int?"
                        AllowClear>
                    <SelectOption TItemValue="int?" TItem="int?" Value="null" Label="全部" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="0" Label="草稿" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="1" Label="招聘中" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="2" Label="已完成" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="3" Label="已取消" />
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="计划日期">
                <RangePicker TValue="DateOnly?[]" Format="yyyy-MM-dd" @bind-Value="DateOnlys" />
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="关键字">
                <Input @bind-Value="@Keyword" Placeholder="职位/计划编号" />
            </FormItem>
        </GridCol>
        <GridCol Span="2">
            <Button OnClick="Refresh" Icon="@IconType.Outline.Search" Type="@ButtonType.Primary" HtmlType="button">
                搜索
            </Button>
        </GridCol>
    </GridRow>
</Form>

<Table DataSource="@data" TItem="RecruitmentPlan" Context="row" Size="TableSize.Small" RowKey="Row => Row.Id"
       Resizable
       HidePagination Bordered
       ScrollX="1800" StickyOffsetHeader="64">
    <PropertyColumn Property="c => c.Code" Title="计划编号" Width="120" Fixed="ColumnFixPlacement.Left" />
    <PropertyColumn Property="c => c.Position" Title="招聘职位" Width="150" Fixed="ColumnFixPlacement.Left" />
    <PropertyColumn Property="c => c.Department.Name" Title="部门" Width="120">
    </PropertyColumn>
    <PropertyColumn Property="c => c.HeadCount" Title="招聘人数" Width="100" Align="ColumnAlign.Right" />
    <PropertyColumn Property="c => c.Education" Title="要求学历" Width="100" />
    <PropertyColumn Property="c => c.Experience" Title="要求经验" Width="120" />
    <PropertyColumn Property="c => c.StartDate" Title="开始日期" Width="120">
        @row.StartDate.ToString("yyyy-MM-dd")
    </PropertyColumn>
    <PropertyColumn Property="c => c.EndDate" Title="结束日期" Width="120">
        @row.EndDate.ToString("yyyy-MM-dd")
    </PropertyColumn>
    <PropertyColumn Property="c => c.Status" Title="状态" Width="100">
        <Tag Color="@(row.Status switch {
            1 => "blue",
            2 => "green",
            3 => "red",
            _ => "default"
        })">
            @row.GetStatusDisplayName()
        </Tag>
    </PropertyColumn>
    <PropertyColumn Property="c => c.InsertTime" Title="创建时间" Width="160" />

    <ActionColumn Title="操作" Width="180" Fixed="ColumnFixPlacement.Right">
        <Space Size="SpaceSize.Small">
            <Button Type="ButtonType.Link" Size="ButtonSize.Small">编辑</Button>
            <Button Type="ButtonType.Link" Size="ButtonSize.Small">查看候选人</Button>
            <Button Type="ButtonType.Link" Size="ButtonSize.Small" Danger>删除</Button>
        </Space>
    </ActionColumn>
</Table>

@code {
    List<Department> Deptlist = Department.Select();
    IEnumerable<string> DeptSelected;
    DateOnly?[] DateOnlys = new DateOnly?[2];
    int? StatusFilter;
    string Keyword;
    RecruitmentPlan FilterModel = new RecruitmentPlan();

    Dictionary<string, int> gutter = new()
    {
        ["xs"] = 8,
        ["sm"] = 16,
        ["md"] = 24,
        ["lg"] = 32,
        ["xl"] = 48,
        ["xxl"] = 64
    };

    List<RecruitmentPlan> data = new List<RecruitmentPlan>();

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    public async Task Refresh()
    {
        try
        {
            SqlClient SSC = new SqlClient();
            var query = SSC.Db.Queryable<RecruitmentPlan>()
                .Includes(p => p.Department)
                .Where(p => p.Active);

            // 部门筛选
            if (DeptSelected != null && DeptSelected.Any())
            {
                var deptIds = Deptlist.Where(d => DeptSelected.Contains(d.Code)).Select(d => d.Code).ToList();
                //query = query.Where(p => deptIds.Contains(p.DepartmentCode));
            }

            // 状态筛选
            if (StatusFilter.HasValue)
            {
                query = query.Where(p => p.Status == StatusFilter.Value);
            }

            // 日期筛选
            if (DateOnlys[0].HasValue)
            {
                query = query.Where(p => p.StartDate >= DateOnlys[0].Value.ToDateTime(TimeOnly.MinValue));
            }
            if (DateOnlys[1].HasValue)
            {
                query = query.Where(p => p.EndDate <= DateOnlys[1].Value.ToDateTime(TimeOnly.MaxValue));
            }

            // 关键字筛选
            if (!string.IsNullOrEmpty(Keyword))
            {
                query = query.Where(p => p.Position.Contains(Keyword) || p.Code.Contains(Keyword));
            }

            data = await query.OrderByDescending(p => p.InsertTime).ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"查询招聘计划失败：{ex.Message}");
            data = new List<RecruitmentPlan>();
        }
    }
}
