@page "/hr/salary/calculate"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AntDesign.TableModels
@using ERP_Web.Models
@using ERP_Web.Repository
@using ERP_Web.Core.Utilities
@using System.Text.Json

<h3>薪资核算</h3>
<Form Model="@FilterModel">
    <GridRow gutter="@gutter">
        <GridCol Span="6">
            <FormItem Label="年度">
                <Select Mode="SelectMode.Default"
                        Placeholder="请选择年度"
                        @bind-Value="@YearFilter"
                        TItemValue="int?"
                        TItem="int?"
                        AllowClear>
                    @for (int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year; i++)
                    {
                        <SelectOption TItemValue="int?" TItem="int?" Value="i" Label=i  />
                    }
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="月份">
                <Select Mode="SelectMode.Default"
                        Placeholder="请选择月份"
                        @bind-Value="@MonthFilter"
                        TItemValue="int?"
                        TItem="int?"
                        AllowClear>
                    @for (int i = 1; i <= 12; i++)
                    {
                        <SelectOption TItemValue="int?" TItem="int?" Value="i" Label=i />
                    }
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="核算状态">
                <Select Mode="SelectMode.Default"
                        Placeholder="请选择状态"
                        @bind-Value="@StatusFilter"
                        TItemValue="int?"
                        TItem="int?"
                        AllowClear>
                    <SelectOption TItemValue="int?" TItem="int?" Value="0" Label="待核算" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="1" Label="核算中" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="2" Label="已完成" />
                    <SelectOption TItemValue="int?" TItem="int?" Value="3" Label="已发放" />
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="2" Offset="10">
            <Button OnClick="Refresh" Icon="@IconType.Outline.Search" Type="@ButtonType.Primary" HtmlType="button">
                搜索
            </Button>
        </GridCol>
    </GridRow>
</Form>

<Table DataSource="@data" TItem="SalaryCalculate" Context="row" Size="TableSize.Small" RowKey="Row => Row.Id"
       Resizable
       HidePagination Bordered
       ScrollX="1800" StickyOffsetHeader="64">
    <PropertyColumn Property="c => c.Year" Title="年度" Width="80" Fixed="ColumnFixPlacement.Left">
        @row.Year 年
    </PropertyColumn>
    <PropertyColumn Property="c => c.Month" Title="月份" Width="80" Fixed="ColumnFixPlacement.Left">
        @row.Month 月
    </PropertyColumn>
    <ActionColumn Title="状态" Width="100">
        <Tag Color="@(row.Status switch {
            <2 => "orange",
            2 => "blue",
            3 => "green",
            _ => "default"
        })">
            @row.GetStatusDisplayName()
        </Tag>
    </ActionColumn>
    <PropertyColumn Property="c => c.TotalEmployee" Title="总人数" Width="100" Align="ColumnAlign.Right" />
    <PropertyColumn Property="c => c.TotalSalary" Title="应发总额" Width="150" Align="ColumnAlign.Right">
        @row.TotalSalary.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.TotalTax" Title="个税总额" Width="150" Align="ColumnAlign.Right">
        @row.TotalTax.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.TotalSocialSecurity" Title="社保公积金总额" Width="150" Align="ColumnAlign.Right">
        @row.TotalSocialSecurity.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.TotalActualSalary" Title="实发总额" Width="150" Align="ColumnAlign.Right">
        @row.TotalActualSalary.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.PayDate" Title="发放日期" Width="120">
        @row.PayDate?.ToString("yyyy-MM-dd") ?? "-"
    </PropertyColumn>
    <PropertyColumn Property="c => c.InsertTime" Title="创建时间" Width="160" />

    <ActionColumn Title="操作" Width="200" Fixed="ColumnFixPlacement.Right">
        <Space Size="SpaceSize.Small">
            <Button Type="ButtonType.Link" Size="ButtonSize.Small" Disabled="@(row.Status >= 2)">核算</Button>
            <Button Type="ButtonType.Link" Size="ButtonSize.Small" Disabled="@(row.Status != 2)">发放</Button>
            <Button Type="ButtonType.Link" Size="ButtonSize.Small">查看工资条</Button>
        </Space>
    </ActionColumn>
</Table>

@code {
    int? YearFilter = DateTime.Now.Year;
    int? MonthFilter = DateTime.Now.Month;
    int? StatusFilter;
    SalaryCalculate FilterModel = new SalaryCalculate();

    Dictionary<string, int> gutter = new()
    {
        ["xs"] = 8,
        ["sm"] = 16,
        ["md"] = 24,
        ["lg"] = 32,
        ["xl"] = 48,
        ["xxl"] = 64
    };

    List<SalaryCalculate> data = new List<SalaryCalculate>();

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    public async Task Refresh()
    {
        try
        {
            SqlClient SSC = new SqlClient();
            var query = SSC.Db.Queryable<SalaryCalculate>()
                .Where(s => s.Active);

            // 年度筛选
            if (YearFilter.HasValue)
            {
                query = query.Where(s => s.Year == YearFilter.Value);
            }

            // 月份筛选
            if (MonthFilter.HasValue)
            {
                query = query.Where(s => s.Month == MonthFilter.Value);
            }

            // 状态筛选
            if (StatusFilter.HasValue)
            {
                query = query.Where(s => s.Status == StatusFilter.Value);
            }

            data = await query.OrderByDescending(s => s.Year).OrderByDescending(s => s.Month).ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"查询薪资核算失败：{ex.Message}");
            data = new List<SalaryCalculate>();
        }
    }
}
