<Form Model="@Pr"
      OnFinish="OnFinish"
      OnFinishFailed="OnFinishFailed"
      LabelColSpan="0"
      WrapperColSpan="20">
    <GridRow Gutter=@gutter>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="代码">
                <Input Disabled @bind-Value="Pr.Code" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4" style="width: 180px">
            <FormItem Label="分类">
                <Select TItem="M.PoTrxGroup"
                        TItemValue="string"
                        DataSource="@PoGrouplist"
                        @bind-Value="Pr.PRTrxGroupCode"
                        ValueName="@nameof(M.PoTrxGroup.Code)"
                        LabelName="@nameof(M.PoTrxGroup.Name)"
                        GroupName="@nameof(M.PoTrxGroup.Note)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Descending"
                        OnSelectedItemChanged="PoTrxGroupChange"
                        Style="width: 100%;">
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4" style="width: 180px">
            <FormItem Label="日期">
                <DatePicker @bind-Value="Pr.Date" Picker="@DatePickerType.Date" style="width: 180px" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4" style="width: 180px">
            <FormItem Label="部门">
                <Select TItem="M.Department"
                        TItemValue="string"
                        DataSource="@Depts"
                        @bind-Value="Dept"
                        ValueName="@nameof(M.Department.Name)"
                        LabelName="@nameof(M.Department.Name)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Ascending"
                        OnSelectedItemChanged="DeptChange"
                        style="width: 180px">
                </Select>
            </FormItem>
        </GridCol>

        <GridCol Class="gutter-row" Span="4" style="width: 180px">
            <FormItem Label="职员">
                <Select TItem="M.Employee"
                        TItemValue="string"
                        DataSource="@Emps"
                        @bind-Value="Emp"
                        ValueName="@nameof(M.Employee.Code)"
                        LabelName="@nameof(M.Employee.Name)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Ascending"
                        OnSelectedItemChanged="EmpChange"
                        style="width: 180px">
                </Select>
            </FormItem>
        </GridCol>

        <GridCol Class="gutter-row" Span="8">
            <FormItem Label="摘要">
                <Input @bind-Value="Pr.Explanation" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="数量">
                <Input @bind-Value="@context.Quantity" style="width: 180px" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="金额">
                <Input @bind-Value="@context.Amount" style="width: 180px" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="含税金额">
                <Input @bind-Value="@context.AmountIncTax" style="width: 150px" />
            </FormItem>
        </GridCol>
    </GridRow>
</Form>
    <button id="startBtn" class="">语音识别开启</button>
