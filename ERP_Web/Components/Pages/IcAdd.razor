@code{

    public string FinalRes { get; set; }
    public string AllRes { get; set; }
    public EventCallback<ChangeEventArgs> FinalResChanged { get; set; }

    private void OnFinalResValueChanged(ChangeEventArgs e)
    {
        FinalRes = e.Value?.ToString();
        InvName = null;
    }

    private void OnAllResValueChanged(ChangeEventArgs e)
    {
        AllRes = e.Value?.ToString();
    }

    private async Task SpeechReturn(){
        AllRes = new(await JS.InvokeAsync<string>("SpeechAllReturn"));
        FinalRes = new(await JS.InvokeAsync<string>("SpeechFinalReturn"));
        FinalRes = Regex.Replace(FinalRes, @"[\p{P}-[.]]", string.Empty);
    }

    void GetRes()
    {
        SpeechReturn().Wait();
        speechToString(AllRes);
    }

    List<string> speechToString(string value)
    {
        List<string> res = [];
        var json = JsonDocument.Parse(value).RootElement;
        var json2 = json.GetProperty("paragraphs");

        foreach (JsonElement je in json2.EnumerateArray())
        {
            var sentences = je.GetProperty("sentences")[1];
            var finalTranscript = sentences.GetProperty("finalTranscript");
            Console.WriteLine($"结果: {finalTranscript.GetString()}");
            if (finalTranscript.GetString() is not null)
                res.Add(finalTranscript.GetString());
        }
        return res;
    }

    private async Task Speechtest()
    {
        string result = "";
        // result = new(await JS.InvokeAsync<string>("SpeechRecognition"));

        result = FinalRes;
		var result2 = AllRes;
    }

}
