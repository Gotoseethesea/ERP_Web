@code {
    bool Modal_visible = false;
    M.IcInv icInv;
    List<M.IcInv> IcInvlist2;
    string InvName;
    IEnumerable<string> InvNames;
    void check()
    {
        if(Ic.InvTrxs[index].InvCode is not null)
        {
            index++;
            RowKey = index + 1;
        }

        if(FinalRes is not null){
            icInv = IcInvlist.Find(x => x.Name.Contains(FinalRes));
            IcInvlist2 = IcInvlist.Where(x => x.Name.Contains(FinalRes)).ToList();

            if (icInv is not null){
                Ic.InvTrxs[index].Inv = icInv;
                Ic.InvTrxs[index].InvCode = icInv.Code;
                SqlClient SSC = new SqlClient();
                M.InventoryBalance inventoryBalance = SSC.Db.Queryable<M.InventoryBalance>()
                .Where(xyz => xyz.WarehouseCode == Ic.WarehouseCode && xyz.InvCode == icInv.Code).First();
                if (Ic.TrxType >= 0) //入库单
                {
                    Ic.InvTrxs[index].UpdatePrice(IcPriceByInvCode(Ic.InvTrxs[index].InvCode));  //从价格表获取最新价格
                }
                else //出库单
                {
                    Ic.InvTrxs[index].PriceIncTax = inventoryBalance?.PriceIncTax ?? 0;  //从库存表获取最新价格
                    Ic.InvTrxs[index].Price = inventoryBalance?.Price ?? 0;
                }

                RowKey = RowKey + 1;
                index = index + 1;
            }
        }
    }
    private void OnSelectedItem(M.IcInv value)
    {
        // Console.WriteLine($"Failed:{JsonSerializer.Serialize(IcInvlist)}");

        if (value != null)
        {
            icInv = value;

            if (Ic.InvTrxs[index].InvCode is null)
            {
                index--;
                RowKey = index - 1;
            }
            SqlClient SSC = new SqlClient();
            M.InventoryBalance inventoryBalance = SSC.Db.Queryable<M.InventoryBalance>().Where(xyz => xyz.WarehouseCode == Ic.WarehouseCode && xyz.InvCode == value.Code).First();
            InvCodeEdit = value.Code;
            Ic.InvTrxs[index].Inv = value;
            Ic.InvTrxs[index].InvCode = value.Code;
        }
        foreach (M.InvTrx invTrx in Ic.InvTrxs.Where(M => M.InvCode is null && M.InvCode != "0"))
        {
            invTrx.InvTrxUpdateCode(Ic.Code);
        }

        if (Ic.InvTrxs.Where(x => x.InvCode is null || x.InvCode == "0").Count() <= 2)
        {
            addRow();
        }
    }
    public class ApiResult
    {
        public List<string[]> result { get; set; }
    }

    M.InvTrx InvTrxRowSelected;
}
