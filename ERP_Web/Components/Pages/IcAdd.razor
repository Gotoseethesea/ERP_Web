{
    Task<string> _oldTask;
    bool _loading;
    int oldInvCode = 0;
    private async Task InvOnSearch(string value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            if (_oldTask == null || _oldTask.IsCompleted)
            {
                _loading = true;
                StateHasChanged();
            }
        }
        _loading = false;
        StateHasChanged();
    }

