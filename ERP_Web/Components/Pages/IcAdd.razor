<div class="center">
    <h3 class="center">单据录入</h3>
</div>

<style>
    .center {
        margin: auto;
        width: 50%;
        padding: 10px;
    }
</style>

<Form Model="@Ic"
      OnFinish="OnFinish"
      OnFinishFailed="OnFinishFailed"
      LabelColSpan="0"
      WrapperColSpan="20">
    <GridRow Gutter=@gutter>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="代码">
                <Input Disabled @bind-Value="@context.Code" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4" style="width: 180px">
            <FormItem Label="分类">
                <Select TItem="M.TrxGroup"
                        TItemValue="string"
                        DataSource="@TrxGrouplist"
                        @bind-Value="@TrxGroup"
                        ValueName="@nameof(M.TrxGroup.Name)"
                        LabelName="@nameof(M.TrxGroup.Name)"
                        GroupName="@nameof(M.TrxGroup.Note)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Descending"
                        OnSelectedItemChanged="IcTrxGroupChange"
                         @* DefaultActiveFirstOption="true" *@
                        Style="width: 100%;">
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4" style="width: 180px">
            <FormItem Label="日期">
                <DatePicker @bind-Value="@context.Date" Picker="@DatePickerType.Date" style="width: 180px" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4" style="width: 180px">
            <FormItem Label="仓库">
                <Select TItem="M.Warehouse"
                        TItemValue="string"
                        DataSource="@Warehouselist"
                        @bind-Value="@WareH"
                        ValueName="@nameof(M.Warehouse.Name)"
                        LabelName="@nameof(M.Warehouse.Name)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Ascending"
                        OnSelectedItemChanged="WarehouseChange"
                        style="width: 180px">
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4" style="width: 180px">
            <FormItem Label="部门">
                <Select TItem="M.Department"
                        TItemValue="string"
                        DataSource="@Departmentlist"
                        @bind-Value="@Dept"
                        ValueName="@nameof(M.Department.Name)"
                        LabelName="@nameof(M.Department.Name)"
                        SortByLabel="@SortDirection.Ascending"
                        SortByGroup="@SortDirection.Ascending"
                        OnSelectedItemChanged="DeptChange"
                        style="width: 180px">
                </Select>
            </FormItem>
        </GridCol>
    </GridRow>

    <GridRow Gutter=@gutter>
        <GridCol Class="gutter-row" Span="8">
            <FormItem Label="摘要">
                <Input @bind-Value="@context.Explanation" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="数量">
                <Input @bind-Value="@context.Quantity" style="width: 180px" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="金额">
                <Input @bind-Value="@context.Amount" style="width: 180px" />
            </FormItem>
        </GridCol>
        <GridCol Class="gutter-row" Span="4">
            <FormItem Label="含税金额">
                <Input @bind-Value="@context.AmountIncTax" style="width: 150px" />
            </FormItem>
        </GridCol>
    </GridRow>
</Form>
