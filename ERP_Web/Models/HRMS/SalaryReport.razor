@page "/hr/report/salary"
@using AntDesign
@using AntDesign.TableModels
@using ERP_Web.Models
@using ERP_Web.Models.HRMS
@using ERP_Web.Repository
@using ERP_Web.Core.Utilities
@using System.Text.Json

<h3>薪资报表</h3>
<Form Model="@FilterModel">
    <GridRow gutter="@gutter">
        <GridCol Span="6">
            <FormItem Label="年度">
                <Select Mode="SelectMode.Default"
                        Placeholder="请选择年度"
                        @bind-Value="@YearFilter"
                        TItemValue="int?"
                        TItem="int?"
                        AllowClear>
                    @for (int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year; i++)
                    {
                        <SelectOption TItemValue="int?" TItem="int?" Value="i" Label="i 年" />
                    }
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="月份">"
                <Select Mode="SelectMode.Default"
                        Placeholder="请选择月份"
                        @bind-Value="@MonthFilter"
                        TItemValue="int?"
                        TItem="int?"
                        AllowClear>
                    @for (int i = 1; i <= 12; i++)
                    {
                        <SelectOption TItemValue="int?" TItem="int?" Value="i" Label= "i 月" />
                    }
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="部门">
                <Select Mode="SelectMode.Multiple"
                        Placeholder="请选择部门"
                        @bind-Values="@DeptSelected"
                        TItemValue="string"
                        TItem="string"
                        EnableSearch
                        AllowClear>
                    <SelectOptions>
                        @foreach (var item in Deptlist)
                        {
                            <SelectOption TItemValue="string" TItem="string" Value=@item.Code Label=@item.Name />
                        }
                    </SelectOptions>
                </Select>
            </FormItem>
        </GridCol>
        <GridCol Span="6">
            <FormItem Label="员工姓名">
                <Input @bind-Value="@Keyword" Placeholder="请输入员工姓名" />
            </FormItem>
        </GridCol>
        <GridCol Span="2">
            <Button OnClick="Refresh" Icon="@IconType.Outline.Search" Type="@ButtonType.Primary" HtmlType="button">
                搜索
            </Button>
            <Button OnClick="Export" Icon="@IconType.Outline.Download" Type="@ButtonType.Default" Style="margin-left: 8px;">
                导出
            </Button>
        </GridCol>
    </GridRow>
</Form>

<Table DataSource="@data" TItem="SalaryReportDto" Context="rowData" Size="TableSize.Small" RowKey="Row => Row.EmployeeId"
       Resizable
       HidePagination Bordered
       ScrollX="2000" StickyOffsetHeader="64">
    <PropertyColumn Property="c => c.EmployeeCode" Title="工号" Width="100" Fixed="ColumnFixPlacement.Left" />
    <PropertyColumn Property="c => c.EmployeeName" Title="姓名" Width="100" Fixed="ColumnFixPlacement.Left" />
    <PropertyColumn Property="c => c.DepartmentName" Title="部门" Width="150" />
    <PropertyColumn Property="c => c.BaseSalary" Title="基本工资" Width="120" Align="ColumnAlign.Right">
        @rowData.BaseSalary.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.PerformanceSalary" Title="绩效工资" Width="120" Align="ColumnAlign.Right">
        @rowData.PerformanceSalary.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.Allowance" Title="补贴合计" Width="120" Align="ColumnAlign.Right">
        @rowData.Allowance.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.OvertimeSalary" Title="加班工资" Width="120" Align="ColumnAlign.Right">
        @rowData.OvertimeSalary.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.TotalSalary" Title="应发合计" Width="120" Align="ColumnAlign.Right">
        <Text Strong>@rowData.TotalSalary.ToString("C0")</Text>
    </PropertyColumn>
    <PropertyColumn Property="c => c.Tax" Title="个税" Width="100" Align="ColumnAlign.Right">
        @rowData.Tax.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.SocialSecurity" Title="社保个人" Width="100" Align="ColumnAlign.Right">
        @rowData.SocialSecurity.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.HousingFund" Title="公积金个人" Width="100" Align="ColumnAlign.Right">
        @rowData.HousingFund.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.Deduction" Title="扣款合计" Width="100" Align="ColumnAlign.Right">
        @rowData.Deduction.ToString("C0")
    </PropertyColumn>
    <PropertyColumn Property="c => c.ActualSalary" Title="实发工资" Width="120" Align="ColumnAlign.Right">
        <Text Strong Type="TextElementType.Success">@rowData.ActualSalary.ToString("C0")</Text>
    </PropertyColumn>
</Table>

<!-- 顶部统计卡片 -->
<Row Style="margin-top: 24px;">
    <Col Span="6">
        <Card Bordered="false" Hoverable>
            <Statistic Title="总人数" Value="@data.Count" Prefix="👥" />
        </Card>
    </Col>
    <Col Span="6">
        <Card Bordered="false" Hoverable>
            <Statistic Title="应发总额" Value="@data.Sum(s => s.TotalSalary)" Prefix="💰" ValueStyle="color: #1890ff" />
        </Card>
    </Col>
    <Col Span="6">
        <Card Bordered="false" Hoverable>
            <Statistic Title="个税总额" Value="@data.Sum(s => s.Tax)" Prefix="💸" ValueStyle="color: #faad14" />
        </Card>
    </Col>
    <Col Span="6">
        <Card Bordered="false" Hoverable>
            <Statistic Title="实发总额" Value="@data.Sum(s => s.ActualSalary)" Prefix="💵" ValueStyle="color: #52c41a" />
        </Card>
    </Col>
</Row>

@code {
    List<Department> Deptlist = Department.Select();
    IEnumerable<string> DeptSelected;
    int? YearFilter = DateTime.Now.Year;
    int? MonthFilter = DateTime.Now.Month;
    string Keyword;
    object FilterModel = new object();

    Dictionary<string, int> gutter = new()
    {
        ["xs"] = 8,
        ["sm"] = 16,
        ["md"] = 24,
        ["lg"] = 32,
        ["xl"] = 48,
        ["xxl"] = 64
    };

    // 薪资报表DTO
    public class SalaryReportDto
    {
        public long EmployeeId { get; set; }
        public string EmployeeCode { get; set; }
        public string EmployeeName { get; set; }
        public string DepartmentName { get; set; }
        public decimal BaseSalary { get; set; }
        public decimal PerformanceSalary { get; set; }
        public decimal Allowance { get; set; }
        public decimal OvertimeSalary { get; set; }
        public decimal TotalSalary { get; set; }
        public decimal Tax { get; set; }
        public decimal SocialSecurity { get; set; }
        public decimal HousingFund { get; set; }
        public decimal Deduction { get; set; }
        public decimal ActualSalary { get; set; }
    }

    List<SalaryReportDto> data = new List<SalaryReportDto>();

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    public async Task Refresh()
    {
        try
        {
            if (!YearFilter.HasValue || !MonthFilter.HasValue) return;

            SqlClient SSC = new SqlClient();
            var query = SSC.Db.Queryable<SalaryRecord>()
                .Includes(s => s.Employee, e => e.Department)
                .Where(s => s.Year == YearFilter.Value && s.Month == MonthFilter.Value && s.Active);

            // 部门筛选
            if (DeptSelected != null && DeptSelected.Any())
            {
                var deptIds = Deptlist.Where(d => DeptSelected.Contains(d.Code)).Select(d => d.Code).ToList();
                query = query.Where(s => deptIds.Contains(s.Employee.DepartmentCode));
            }

            // 姓名筛选
            if (!string.IsNullOrEmpty(Keyword))
            {
                query = query.Where(s => s.Employee.Name.Contains(Keyword));
            }

            data = await query.Select(s => new SalaryReportDto
            {
                EmployeeId = s.EmployeeId,
                EmployeeCode = s.Employee.Code,
                EmployeeName = s.Employee.Name,
                DepartmentName = s.Employee.Department.Name,
                BaseSalary = s.BaseSalary,
                PerformanceSalary = s.PerformanceSalary,
                Allowance = s.Allowance,
                OvertimeSalary = s.OvertimeSalary,
                TotalSalary = s.TotalSalary,
                Tax = s.Tax,
                SocialSecurity = s.SocialSecurityPersonal,
                HousingFund = s.HousingFundPersonal,
                Deduction = s.Deduction,
                ActualSalary = s.ActualSalary
            }).ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"查询薪资报表失败：{ex.Message}");
            data = new List<SalaryReportDto>();
        }
    }

    private void Export()
    {
        // 导出逻辑和现有报表保持一致
    }
}
