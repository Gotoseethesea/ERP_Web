@page "/module-selector2"
@using Microsoft.AspNetCore.Authorization
@using ERP.Shared.EAM
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject NavigationManager NavManager
@inject IJSRuntime JsRuntime

<Row Align="RowAlign.Middle" Justify="RowJustify.Center" Style="min-height:100vh;background:linear-gradient(135deg, #667eea 0%, #764ba2 100%);padding:32px 0">
    <Col Style="width:100%;max-width:1200px">
    <div Style="text-align:center;margin-bottom:48px">
        <Title Level="2" Style="color:#fff;margin-bottom:8px">ERP管理系统</Title>
        <Text Style="color:rgba(255,255,255,0.8)">请选择业务模块</Text>
    </div>
    <GridRow gutter="24">
        <!-- 进销存模块 -->
        <GridCol Lg="8" Md="12" Xs="24" Style="margin-bottom:24px">
            <div @onclick="() => SelectModule(PSI)" style="cursor: pointer;height:100%">
                <Card Hoverable
                      Style="width:100%;height:100%;border-radius:12px;cursor:pointer"
                      BodyStyle="padding:48px 24px;text-align:center">
                    <Icon Type="shop" Style="font-size:64px;color:#1890ff;margin-bottom:16px" />
                    <Title Level="3" Style="margin-bottom:12px">进销存管理</Title>
                    <Text Type="TextElementType.Secondary">采购管理、库存管控、出入库单据、库存报表</Text>
                </Card>
            </div>
        </GridCol>

        <!-- 销售模块 -->
        <GridCol Lg="8" Md="12" Xs="24" Style="margin-bottom:24px">
            <div @onclick="() => SelectModule(SMS)" style="cursor: pointer;height:100%">
                <Card Hoverable
                      Style="width:100%;height:100%;border-radius:12px;cursor:pointer"
                      BodyStyle="padding:48px 24px;text-align:center">
                    <Icon Type="dollar" Style="font-size:64px;color:#faad14;margin-bottom:16px" />
                    <Title Level="3" Style="margin-bottom:12px">销售管理</Title>
                    <Text Type="TextElementType.Secondary">客户管理、销售订单、业绩统计、回款跟踪</Text>
                </Card>
            </div>
        </GridCol>

        <!-- 人事模块 -->
        <GridCol Lg="8" Md="12" Xs="24" Style="margin-bottom:24px">
            <div @onclick="() => SelectModule(HR)" style="cursor: pointer;height:100%">
                <Card Hoverable
                      Style="width:100%;height:100%;border-radius:12px;cursor:pointer"
                      BodyStyle="padding:48px 24px;text-align:center">
                    <Icon Type="team" Style="font-size:64px;color:#52c41a;margin-bottom:16px" />
                    <Title Level="3" Style="margin-bottom:12px">人事管理</Title>
                    <Text Type="TextElementType.Secondary">员工档案、考勤薪资、招聘管理、组织架构</Text>
                </Card>
            </div>
        </GridCol>

        <!-- 资产管理 -->
        <GridCol Lg="8" Md="12" Xs="24" Style="margin-bottom:24px">
            <div @onclick="() => SelectModule(EAM)" style="cursor: pointer;height:100%">
                <Card Hoverable
                      Style="width:100%;height:100%;border-radius:12px;cursor:pointer"
                      BodyStyle="padding:48px 24px;text-align:center">
                    <Icon Type="desktop" Style="font-size:64px;color:#722ed1;margin-bottom:16px" />
                    <Title Level="3" Style="margin-bottom:12px">资产管理</Title>
                    <Text Type="TextElementType.Secondary">资产台账、领用归还、维保记录、资产盘点</Text>
                </Card>
            </div>
        </GridCol>

        <!-- 财务模块 -->
        <GridCol Lg="8" Md="12" Xs="24" Style="margin-bottom:24px">
            <div @onclick="() => SelectModule(FMS)" style="cursor: pointer;height:100%">
                <Card Hoverable
                      Style="width:100%;height:100%;border-radius:12px;cursor:pointer"
                      BodyStyle="padding:48px 24px;text-align:center">
                    <Icon Type="account-book" Style="font-size:64px;color:#f5222d;margin-bottom:16px" />
                    <Title Level="3" Style="margin-bottom:12px">财务管理</Title>
                    <Text Type="TextElementType.Secondary">凭证管理、应收应付、财务报表、预算管控</Text>
                </Card>
            </div>
        </GridCol>

        <!-- 工程模块 -->
        <GridCol Lg="8" Md="12" Xs="24" Style="margin-bottom:24px">
            <div @onclick="() => SelectModule(EMS)" style="cursor: pointer;height:100%">
                <Card Hoverable
                      Style="width:100%;height:100%;border-radius:12px;cursor:pointer"
                      BodyStyle="padding:48px 24px;text-align:center">
                    <Icon Type="tool" Style="font-size:64px;color:#13c2c2;margin-bottom:16px" />
                    <Title Level="3" Style="margin-bottom:12px">工程管理</Title>
                    <Text Type="TextElementType.Secondary">项目管理、进度跟踪、工单管理、物料核算</Text>
                </Card>
            </div>
        </GridCol>

        @foreach (var module in SysModels)
        {
            <GridCol Lg="8" Md="12" Xs="24" Style="margin-bottom:24px">
                <div @onclick="() => SelectModule(module.Code)" style="cursor: pointer;height:100%">
                    <Card Hoverable
                          Style="width:100%;height:100%;border-radius:12px;cursor:pointer"
                          BodyStyle="padding:48px 24px;text-align:center">
                        <Icon Type="@module.Icon" Style="@module.Style" />
                        <Title Level="3" Style="margin-bottom:12px">@module.Name</Title>
                        <Text Type="TextElementType.Secondary">@module.Description</Text>
                    </Card>
                </div>
            </GridCol>
        }
    </GridRow>
    <div Style="text-align:center;margin-top:24px">
        <Text Style="color:rgba(255,255,255,0.6)">© 2026 ERP管理系统 | 版本 V1.0</Text>
    </div>
</Col>
</Row>

@code {
    string PSI = "PSI"; //进销存系统
    string SMS = "SMS"; // 销售系统
    string HR = "HR";  //人事系统
    string EAM = "EAM"; //资产管理系统
    string FMS = "FMS"; //财务系统
    string EMS = "EMS"; //工程系统
    List<SystemBusinessModule> SysModels;


    protected override async Task OnInitializedAsync()
    {
        //await Refresh();
        SysModels = SystemBusinessModule.Select();
    }


    private async Task SelectModule(string module)
    {
        await JsRuntime.InvokeVoidAsync("localStorage.setItem", "currentModule", module);
        NavManager.NavigateTo("/");
    }
}
